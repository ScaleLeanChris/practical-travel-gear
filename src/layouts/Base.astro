---
import { getMenu, getTaxonomyTerms } from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import CatIcon from "../components/CatIcon.astro";
import "../styles/theme.css";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
} = Astro.props;
const siteTitle = "Practical Travel Gear";
const fullTitle = title.includes(siteTitle) ? title : `${title} | ${siteTitle}`;

const [socialMenu, tags] = await Promise.all([
	getMenu("social"),
	getTaxonomyTerms("tag"),
]);

// Activity-led primary nav. Hardcoded to match the design — these are
// category taxonomy links; terms don't all exist yet but will be created
// as content gets tagged.
const navItems: Array<{ label: string; url: string; icon: string | null }> = [
	{ label: "Home", url: "/", icon: null },
	{ label: "Luggage", url: "/category/luggage", icon: "luggage" },
	{ label: "Packs", url: "/category/packs", icon: "pack" },
	{ label: "Apparel", url: "/category/apparel", icon: "shirt" },
	{ label: "Footwear", url: "/category/footwear", icon: "boot" },
	{ label: "Tech", url: "/category/tech", icon: "cable" },
	{ label: "Accessories", url: "/category/accessories", icon: "tag" },
	{ label: "Camping", url: "/category/camping", icon: "tent" },
];

const currentPath = Astro.url.pathname;

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

const isLoggedIn = !!Astro.locals.user;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<meta name="keywords" content="Travel Gear, Travel Accessories, Travel Gadgets, Travel Reviews" />
		<meta name="msvalidate.01" content="07E94CDED103E81EC7F6E0E82FAB530C" />
		<meta name="google-site-verification" content="EcYP6zf6ISsPzc-RbCRJLuPGMMdsuh05-8EyyvSR59A" />
		<meta name="p:domain_verify" content="289fb7405ceb69ac12f7a6fde776fe22" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "http://schema.org",
			"@type": "WebSite",
			"@id": "#website",
			"url": "https://practicaltravelgear.com/",
			"name": "Practical Travel Gear",
			"potentialAction": {
				"@type": "SearchAction",
				"target": "https://practicaltravelgear.com/search?q={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		})} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "http://schema.org",
			"@type": "Organization",
			"url": "https://practicaltravelgear.com/",
			"sameAs": [
				"https://www.facebook.com/practicaltravelgear/",
				"https://www.pinterest.com/practicaltr0284/"
			],
			"@id": "#organization",
			"name": "Practical Travel Gear"
		})} />
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-PJBZDDT9KH"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-PJBZDDT9KH');
		</script>
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		<header class="site-header">
			<!-- Main header: logo + subscribe -->
			<div class="header-main">
				<a href="/" class="site-logo">
					<img src="/images/PTG_Logo_Full.png" alt={siteTitle} />
				</a>
				<div class="header-actions">
					<button type="button" class="header-search-icon" id="search-toggle" aria-label="Search">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
					</button>
					<a href="/subscribe" class="btn-subscribe">Subscribe</a>
				</div>
			</div>

			<!-- Search overlay -->
			<div class="search-overlay" id="search-overlay">
				<div class="search-overlay-inner">
					<LiveSearch
						placeholder="Search 2,400+ reviews and guides…"
						class="site-search"
						inputClass="site-search-input"
						resultsClass="site-search-results"
						resultClass="site-search-result"
						collections={["posts", "pages"]}
					/>
					<button class="search-close" id="search-close" aria-label="Close search">&times;</button>
				</div>
			</div>

			<!-- Category navigation -->
			<nav class="cat-nav-wrap">
				<div class="cat-nav">
					{navItems.map((item) => {
						const active = item.url === "/"
							? currentPath === "/"
							: currentPath.startsWith(item.url);
						return (
							<a href={item.url} class={active ? "active" : ""}>
								{item.icon && <CatIcon name={item.icon} />}
								{item.label}
							</a>
						);
					})}
				</div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-top container">
				<div class="footer-newsletter">
					<div class="footer-brand">
						<img src="/images/PTG_Logo.png" alt="PTG" />
						<strong>Practical Travel Gear</strong>
					</div>
					<h4>The Departure Lounge</h4>
					<p>Weekly picks, gear notes, and travel briefs. No filler.</p>
					<form class="sub-row" onsubmit="event.preventDefault();">
						<input type="email" placeholder="you@domain.com" aria-label="Email address" />
						<button type="submit">Sign up</button>
					</form>
				</div>
				<div class="footer-col">
					<h4>Categories</h4>
					<div class="footer-links">
						{navItems.filter((i) => i.url !== "/").map((item) => (
							<a href={item.url}>{item.label}</a>
						))}
					</div>
				</div>
				<div class="footer-col">
					<h4>Popular Tags</h4>
					<div class="footer-tags">
						{tags.slice(0, 10).map((tag) => (
							<a href={`/tag/${tag.slug}`} class="footer-tag">{tag.label}</a>
						))}
					</div>
				</div>
				<div class="footer-col">
					<h4>Follow</h4>
					<div class="footer-links">
						{socialMenu?.items.map((item) => (
							<a href={item.url} target={item.target} rel={item.target === '_blank' ? 'noopener noreferrer' : undefined}>{item.label}</a>
						))}
					</div>
				</div>
				<div class="footer-col">
					<h4>About</h4>
					<WidgetArea name="footer" />
					<div class="footer-links" style="margin-top: var(--spacing-3);">
						<a href="/_emdash/admin" class="footer-admin">{isLoggedIn ? 'Admin' : 'Login'}</a>
					</div>
				</div>
			</div>
			<div class="footer-bottom container">
				<span>&copy; {new Date().getFullYear()} Practical Travel Gear &middot; Since 2007</span>
				<span>Independently tested. Reader supported.</span>
			</div>
		</footer>

		<script>
			const searchToggle = document.getElementById('search-toggle');
			const searchOverlay = document.getElementById('search-overlay');
			const searchClose = document.getElementById('search-close');

			function openSearch() {
				searchOverlay?.classList.add('active');
				const input = searchOverlay?.querySelector('input');
				if (input) setTimeout(() => (input as HTMLInputElement).focus(), 100);
			}
			function closeSearch() { searchOverlay?.classList.remove('active'); }

			searchToggle?.addEventListener('click', (e) => { e.preventDefault(); openSearch(); });
			searchClose?.addEventListener('click', closeSearch);

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') closeSearch();
				if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
					e.preventDefault();
					openSearch();
				}
			});
		</script>

		<style is:global>
			*:where(:not([class*="emdash"]):not([class*="ec-"])),
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::before,
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::after {
				box-sizing: border-box;
			}

			body, h1, h2, h3, h4, h5, h6, p, ul, ol, figure, blockquote, dl, dd {
				margin: 0;
			}
			ul, ol { padding: 0; }

			html { scroll-behavior: smooth; }

			body {
				font-family: var(--font-sans);
				font-size: var(--font-size-base);
				line-height: var(--leading-relaxed);
				color: var(--ink);
				background: var(--bg);
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				min-height: 100vh;
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])) {
				color: inherit;
				text-decoration: none;
				transition: color var(--transition-fast);
			}

			img {
				max-width: 100%;
				height: auto;
				display: block;
			}

			h1, h2, h3, h4, h5, h6 {
				font-family: var(--font-display);
				line-height: var(--leading-tight);
				font-weight: 700;
				color: var(--ink);
				letter-spacing: var(--tracking-snug);
			}

			::selection {
				background: var(--accent);
				color: white;
			}
		</style>

		<style>
			/* ===== HEADER ===== */
			.site-header {
				background: var(--bg);
				border-bottom: 1px solid var(--rule);
				position: sticky;
				top: 0;
				z-index: 50;
			}

			/* Main header: logo left, subscribe right */
			.header-main {
				max-width: var(--maxw);
				margin: 0 auto;
				padding: 20px 24px 16px;
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 24px;
			}

			.site-logo {
				display: inline-flex;
				align-items: center;
			}
			.site-logo img {
				height: 48px;
				width: auto;
				display: block;
			}

			.header-actions {
				display: flex;
				align-items: center;
				gap: 8px;
			}

			.header-search-icon {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 38px;
				height: 38px;
				border-radius: 50%;
				background: transparent;
				color: var(--ink-3);
				border: 0;
				cursor: pointer;
				transition: background var(--transition-fast), color var(--transition-fast);
			}
			.header-search-icon:hover {
				background: var(--surface);
				color: var(--ink);
			}

			.btn-subscribe {
				display: inline-flex;
				align-items: center;
				padding: 10px 22px;
				background: var(--ink);
				color: var(--bg);
				border-radius: 999px;
				font-size: 14px;
				font-weight: 600;
				letter-spacing: -0.005em;
				transition: background var(--transition-fast);
			}
			.btn-subscribe:hover { background: var(--accent); color: white; }

			/* Search overlay */
			.search-overlay {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(11, 20, 16, 0.55);
				z-index: 1000;
				align-items: flex-start;
				justify-content: center;
				padding-top: 15vh;
			}
			.search-overlay.active { display: flex; }

			.search-overlay-inner {
				background: var(--bg);
				border: 1px solid var(--rule);
				border-radius: var(--radius-lg);
				padding: var(--spacing-6);
				width: 90%;
				max-width: 600px;
				position: relative;
				box-shadow: 0 20px 60px rgba(0,0,0,0.15);
			}

			.search-close {
				position: absolute;
				top: 8px;
				right: 14px;
				background: none;
				border: none;
				font-size: 24px;
				cursor: pointer;
				color: var(--ink-3);
				line-height: 1;
			}
			.search-close:hover { color: var(--ink); }

			:global(.site-search) { width: 100%; }
			:global(.site-search-input) {
				width: 100%;
				padding: var(--spacing-3) var(--spacing-4);
				font-family: var(--font-sans);
				font-size: var(--font-size-lg);
				border: 1px solid var(--rule);
				border-radius: var(--radius-lg);
				background: var(--surface);
				color: var(--ink);
			}
			:global(.site-search-input)::placeholder { color: var(--ink-3); }
			:global(.site-search-input):focus,
			:global(.site-search-input):focus-visible {
				outline: none;
				border-color: var(--accent);
			}
			:global(.site-search-results) {
				margin-top: var(--spacing-2);
				background: var(--bg);
				border: 1px solid var(--rule);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-dropdown);
				max-height: 400px;
				overflow-y: auto;
			}
			:global(.site-search-results .emdash-live-search-loading),
			:global(.site-search-results .emdash-live-search-no-results) {
				padding: var(--spacing-4);
				text-align: center;
				color: var(--ink-3);
				font-size: var(--font-size-sm);
			}
			:global(.site-search-result) {
				display: block;
				padding: var(--spacing-3) var(--spacing-4);
				text-decoration: none;
				color: var(--ink);
				border-bottom: 1px solid var(--rule);
			}
			:global(.site-search-result):last-child { border-bottom: none; }
			:global(.site-search-result):hover,
			:global(.site-search-result):focus,
			:global(.site-search-result.focused) { background: var(--surface); }
			:global(.site-search-result .emdash-live-search-result-title) {
				display: block;
				font-weight: 600;
				font-size: var(--font-size-sm);
			}
			:global(.site-search-result .emdash-live-search-result-collection) {
				display: block;
				font-family: var(--font-mono);
				font-size: 10px;
				color: var(--ink-3);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-top: 2px;
			}
			:global(.site-search-result .emdash-live-search-result-snippet) {
				display: block;
				font-size: var(--font-size-sm);
				color: var(--ink-3);
				margin-top: var(--spacing-1);
			}
			:global(.site-search-result .emdash-live-search-result-snippet mark) {
				font-weight: 600;
				color: var(--ink);
				background: var(--accent-soft);
			}

			/* Category nav */
			.cat-nav-wrap { border-top: 1px solid var(--rule); }
			.cat-nav {
				max-width: var(--maxw);
				margin: 0 auto;
				padding: 0 24px;
				display: flex;
				align-items: center;
				gap: 0;
				overflow-x: auto;
				scrollbar-width: none;
			}
			.cat-nav::-webkit-scrollbar { display: none; }
			.cat-nav a {
				padding: 14px 18px;
				font-size: 14px;
				font-weight: 500;
				color: var(--ink-2);
				white-space: nowrap;
				border-bottom: 2px solid transparent;
				margin-bottom: -1px;
				transition: color var(--transition-fast), border-color var(--transition-fast);
				display: flex;
				align-items: center;
				gap: 8px;
			}
			.cat-nav a:first-child { padding-left: 0; }
			.cat-nav a:hover { color: var(--accent); }
			.cat-nav a.active {
				color: var(--ink);
				font-weight: 700;
				border-bottom-color: var(--accent);
			}
			.cat-nav a :global(svg) {
				width: 16px;
				height: 16px;
				color: var(--ink-3);
				flex-shrink: 0;
			}
			.cat-nav a:hover :global(svg) { color: var(--accent); }
			.cat-nav a.active :global(svg) { color: var(--ink); }

			/* ===== FOOTER ===== */
			.site-footer {
				margin-top: var(--spacing-16);
				background: var(--surface);
				border-top: 1px solid var(--rule);
				padding: 48px 0 20px;
			}
			.footer-top {
				display: grid;
				grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr;
				gap: 32px;
				padding-bottom: 40px;
				border-bottom: 1px solid var(--rule);
				margin-bottom: 20px;
			}
			.footer-brand {
				display: flex;
				align-items: center;
				gap: 10px;
				margin-bottom: 14px;
			}
			.footer-brand img { height: 28px; width: auto; }
			.footer-brand strong {
				font-size: 14px;
				font-weight: 700;
				letter-spacing: -0.01em;
			}

			.footer-top h4 {
				font-family: var(--font-mono);
				font-size: 11px;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--ink-3);
				margin: 0 0 14px;
			}

			.footer-newsletter p {
				font-size: 14px;
				color: var(--ink-2);
				line-height: 1.5;
				margin: 0 0 16px;
				max-width: 340px;
			}
			.footer-newsletter .sub-row {
				display: flex;
				gap: 8px;
				max-width: 380px;
			}
			.footer-newsletter input {
				flex: 1;
				padding: 10px 14px;
				border: 1px solid var(--rule-2);
				border-radius: 999px;
				font: inherit;
				font-size: 13px;
				outline: none;
				background: var(--bg);
				color: var(--ink);
			}
			.footer-newsletter input:focus { border-color: var(--ink); }
			.footer-newsletter button {
				padding: 10px 18px;
				background: var(--accent);
				color: white;
				border: 0;
				border-radius: 999px;
				font-weight: 600;
				font-size: 13px;
				cursor: pointer;
				transition: background var(--transition-fast);
			}
			.footer-newsletter button:hover { background: var(--accent-2); }

			.footer-links {
				display: flex;
				flex-direction: column;
				gap: 8px;
				font-size: 13px;
			}
			.footer-links a { color: var(--ink-2); }
			.footer-links a:hover { color: var(--accent); }

			.footer-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 6px;
			}
			.footer-tag {
				display: inline-block;
				padding: 4px 10px;
				font-size: 12px;
				color: var(--ink-2);
				background: var(--bg);
				border: 1px solid var(--rule);
				border-radius: 999px;
				transition: color var(--transition-fast), border-color var(--transition-fast);
			}
			.footer-tag:hover { color: var(--accent); border-color: var(--accent); }

			.footer-bottom {
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-family: var(--font-mono);
				font-size: 11px;
				color: var(--ink-3);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.footer-admin { color: var(--ink-3) !important; }
			.footer-admin:hover { color: var(--accent) !important; }

			/* Footer widget overrides */
			.footer-col :global(.widget-area) { display: block; }
			.footer-col :global(.widget__title) { display: none; }
			.footer-col :global(.widget__content) {
				color: var(--ink-2);
				font-size: 13px;
				line-height: 1.55;
			}

			/* ===== RESPONSIVE ===== */
			@media (max-width: 1100px) {
				.footer-top { grid-template-columns: 1.4fr 1fr 1fr; }
				.footer-top > :nth-child(n+4) { display: none; }
			}
			@media (max-width: 900px) {
				.header-main { padding: 14px 16px; }
				.site-logo img { height: 40px; }
				.btn-subscribe { padding: 8px 16px; font-size: 13px; }
				.cat-nav a { padding: 12px 12px; font-size: 13px; }
				.footer-top { grid-template-columns: 1fr; gap: 28px; }
				.footer-top > :nth-child(n+4) { display: block; }
				.footer-bottom { flex-direction: column; gap: 6px; text-align: center; }
			}
			@media (max-width: 640px) {
				.site-logo img { height: 36px; }
				.btn-subscribe { padding: 7px 14px; font-size: 12px; }
			}
		</style>

		<!-- Shared CatIcon component for inline use in nav -->
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
