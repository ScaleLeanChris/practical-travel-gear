---
import { getMenu, getTaxonomyTerms } from "emdash";
import {
	WidgetArea,
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import CatIcon from "../components/CatIcon.astro";
import "../styles/theme.css";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	robots?: string | null;
	type?: "website" | "article";
	publishedTime?: string | null;
	modifiedTime?: string | null;
	author?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}

const {
	title,
	description,
	image,
	canonical,
	robots,
	type = "website",
	publishedTime,
	modifiedTime,
	author,
	content,
} = Astro.props;
const siteTitle = "Practical Travel Gear";
const siteTagline = "Honest Travel Gear Reviews and Advice";
const fullTitle = title.includes(siteTitle) ? title : `${title} | ${siteTitle}`;

const [menu, socialMenu, tags] = await Promise.all([
	getMenu("primary"),
	getMenu("social"),
	getTaxonomyTerms("tag"),
]);

const socialIcons: Record<string, string> = {
	facebook: '<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>',
	instagram: '<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>',
	pinterest: '<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>',
	rss: '<svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.742-7.099-15.783-15.839-15.82zm0-8.18v4.819c12.951.115 23.409 10.627 23.523 23.564h4.477c-.115-15.764-12.843-28.512-28-28.383z"/></svg>',
};

// Map nav labels (as stored in seed) to an icon name for the category nav
const navIcons: Record<string, string> = {
	luggage: "luggage",
	packs: "pack",
	backpacks: "pack",
	apparel: "shirt",
	footwear: "boot",
	tech: "cable",
	accessories: "tag",
	guides: "tent",
	posts: "map",
	reviews: "tent",
};

function getSocialKey(label: string): string {
	return label.toLowerCase();
}
function getNavIconKey(label: string): string | null {
	const key = label.toLowerCase();
	return navIcons[key] ?? null;
}

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: type,
	title: fullTitle,
	description,
	canonical,
	image,
	content,
	seo: { ogImage: image, robots },
	articleMeta: { publishedTime, modifiedTime, author },
	siteName: siteTitle,
});

const isLoggedIn = !!Astro.locals.user;

const todayLabel = new Date().toLocaleDateString("en-US", {
	weekday: "short",
	month: "short",
	day: "numeric",
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<meta name="keywords" content="Travel Gear, Travel Accessories, Travel Gadgets, Travel Reviews" />
		<meta name="msvalidate.01" content="07E94CDED103E81EC7F6E0E82FAB530C" />
		<meta name="google-site-verification" content="EcYP6zf6ISsPzc-RbCRJLuPGMMdsuh05-8EyyvSR59A" />
		<meta name="p:domain_verify" content="289fb7405ceb69ac12f7a6fde776fe22" />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "http://schema.org",
			"@type": "WebSite",
			"@id": "#website",
			"url": "https://practicaltravelgear.com/",
			"name": "Practical Travel Gear",
			"potentialAction": {
				"@type": "SearchAction",
				"target": "https://practicaltravelgear.com/search?q={search_term_string}",
				"query-input": "required name=search_term_string"
			}
		})} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "http://schema.org",
			"@type": "Organization",
			"url": "https://practicaltravelgear.com/",
			"sameAs": [
				"https://www.facebook.com/practicaltravelgear/",
				"https://www.pinterest.com/practicaltr0284/"
			],
			"@id": "#organization",
			"name": "Practical Travel Gear"
		})} />
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-PJBZDDT9KH"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-PJBZDDT9KH');
		</script>
		<EmDashHead page={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart page={pageCtx} />

		<header class="site-header">
			<!-- Utility strip -->
			<div class="header-utility">
				<div class="header-utility-inner">
					<div class="util-l">
						<span><span class="util-dot"></span> Honest travel gear reviews &middot; tested &amp; trusted since 2007</span>
					</div>
					<div class="util-r">
						{socialMenu?.items.slice(0, 4).map((item) => {
							const key = getSocialKey(item.label);
							return (
								<a href={item.url} target={item.target} rel={item.target === '_blank' ? 'noopener noreferrer' : undefined} aria-label={item.label} class="util-social">
									<Fragment set:html={socialIcons[key] || socialIcons.rss} />
								</a>
							);
						})}
						<span class="util-date">{todayLabel}</span>
					</div>
				</div>
			</div>

			<!-- Main header: logo + search -->
			<div class="header-main">
				<div class="header-main-spacer"></div>
				<a href="/" class="site-logo">
					<img src="/images/PTG_Logo_Full.png" alt={siteTitle} />
				</a>
				<div class="header-actions">
					<button type="button" class="header-search-toggle" id="search-toggle" aria-label="Search">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
						<span>Search</span>
						<kbd>⌘K</kbd>
					</button>
				</div>
			</div>

			<!-- Search overlay -->
			<div class="search-overlay" id="search-overlay">
				<div class="search-overlay-inner">
					<LiveSearch
						placeholder="Search 2,400+ reviews and guides…"
						class="site-search"
						inputClass="site-search-input"
						resultsClass="site-search-results"
						resultClass="site-search-result"
						collections={["posts", "pages"]}
					/>
					<button class="search-close" id="search-close" aria-label="Close search">&times;</button>
				</div>
			</div>

			<!-- Category navigation -->
			<nav class="cat-nav-wrap">
				<div class="cat-nav">
					{menu?.items.map((item) => {
						const iconKey = getNavIconKey(item.label);
						return (
							<a href={item.url} target={item.target}>
								{iconKey && <CatIcon name={iconKey} />}
								{item.label}
							</a>
						);
					})}
				</div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-top container">
				<div class="footer-newsletter">
					<div class="footer-brand">
						<img src="/images/PTG_Logo.png" alt="PTG" />
						<strong>Practical Travel Gear</strong>
					</div>
					<h4>The Departure Lounge</h4>
					<p>Weekly picks, gear notes, and travel briefs. No filler.</p>
					<form class="sub-row" onsubmit="event.preventDefault();">
						<input type="email" placeholder="you@domain.com" aria-label="Email address" />
						<button type="submit">Sign up</button>
					</form>
				</div>
				<div class="footer-col">
					<h4>Sections</h4>
					<div class="footer-links">
						{menu?.items.map((item) => (
							<a href={item.url} target={item.target}>{item.label}</a>
						))}
					</div>
				</div>
				<div class="footer-col">
					<h4>Popular Tags</h4>
					<div class="footer-tags">
						{tags.slice(0, 10).map((tag) => (
							<a href={`/tag/${tag.slug}`} class="footer-tag">{tag.label}</a>
						))}
					</div>
				</div>
				<div class="footer-col">
					<h4>Follow</h4>
					<div class="footer-links">
						{socialMenu?.items.map((item) => (
							<a href={item.url} target={item.target} rel={item.target === '_blank' ? 'noopener noreferrer' : undefined}>{item.label}</a>
						))}
					</div>
				</div>
				<div class="footer-col">
					<h4>About</h4>
					<WidgetArea name="footer" />
					<div class="footer-links" style="margin-top: var(--spacing-3);">
						<a href="/_emdash/admin" class="footer-admin">{isLoggedIn ? 'Admin' : 'Login'}</a>
					</div>
				</div>
			</div>
			<div class="footer-bottom container">
				<span>&copy; {new Date().getFullYear()} Practical Travel Gear &middot; Since 2007</span>
				<span>Independently tested. Reader supported.</span>
			</div>
		</footer>

		<script>
			const searchToggle = document.getElementById('search-toggle');
			const searchOverlay = document.getElementById('search-overlay');
			const searchClose = document.getElementById('search-close');

			function openSearch() {
				searchOverlay?.classList.add('active');
				const input = searchOverlay?.querySelector('input');
				if (input) setTimeout(() => (input as HTMLInputElement).focus(), 100);
			}
			function closeSearch() { searchOverlay?.classList.remove('active'); }

			searchToggle?.addEventListener('click', (e) => { e.preventDefault(); openSearch(); });
			searchClose?.addEventListener('click', closeSearch);

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') closeSearch();
				if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
					e.preventDefault();
					openSearch();
				}
			});
		</script>

		<style is:global>
			*:where(:not([class*="emdash"]):not([class*="ec-"])),
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::before,
			*:where(:not([class*="emdash"]):not([class*="ec-"]))::after {
				box-sizing: border-box;
			}

			body, h1, h2, h3, h4, h5, h6, p, ul, ol, figure, blockquote, dl, dd {
				margin: 0;
			}
			ul, ol { padding: 0; }

			html { scroll-behavior: smooth; }

			body {
				font-family: var(--font-sans);
				font-size: var(--font-size-base);
				line-height: var(--leading-relaxed);
				color: var(--ink);
				background: var(--bg);
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				min-height: 100vh;
			}

			a:where(:not([class*="emdash"]):not([class*="ec-"])) {
				color: inherit;
				text-decoration: none;
				transition: color var(--transition-fast);
			}

			img {
				max-width: 100%;
				height: auto;
				display: block;
			}

			h1, h2, h3, h4, h5, h6 {
				font-family: var(--font-display);
				line-height: var(--leading-tight);
				font-weight: 700;
				color: var(--ink);
				letter-spacing: var(--tracking-snug);
			}

			::selection {
				background: var(--accent);
				color: white;
			}
		</style>

		<style>
			/* ===== HEADER ===== */
			.site-header {
				background: var(--bg);
				border-bottom: 1px solid var(--rule);
				position: sticky;
				top: 0;
				z-index: 50;
			}

			.header-utility {
				border-bottom: 1px solid var(--rule);
				background: var(--surface);
			}

			.header-utility-inner {
				max-width: var(--maxw);
				margin: 0 auto;
				padding: 7px 24px;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-family: var(--font-mono);
				font-size: 11px;
				color: var(--ink-3);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}

			.util-l, .util-r {
				display: flex;
				align-items: center;
				gap: 14px;
			}

			.util-social {
				display: inline-flex;
				align-items: center;
				color: var(--ink-3);
				opacity: 0.7;
				transition: color var(--transition-fast), opacity var(--transition-fast);
			}
			.util-social:hover { color: var(--accent); opacity: 1; }

			.util-date {
				padding-left: 14px;
				border-left: 1px solid var(--rule-2);
			}

			.util-dot {
				display: inline-block;
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent);
				margin-right: 6px;
				vertical-align: middle;
				animation: pulse 2s infinite;
			}

			@keyframes pulse {
				0%, 100% { opacity: 1; }
				50% { opacity: 0.4; }
			}

			/* Main header */
			.header-main {
				max-width: var(--maxw);
				margin: 0 auto;
				padding: 18px 24px;
				display: grid;
				grid-template-columns: 1fr auto 1fr;
				align-items: center;
				gap: 24px;
			}

			.header-main-spacer { display: block; }

			.site-logo {
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.site-logo img {
				height: 52px;
				width: auto;
				display: block;
			}

			.header-actions {
				display: flex;
				justify-content: flex-end;
				align-items: center;
				gap: 8px;
			}

			.header-search-toggle {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 8px 14px;
				background: var(--surface);
				border: 1px solid var(--rule);
				border-radius: 999px;
				color: var(--ink-3);
				font-size: 13px;
				cursor: pointer;
				transition: border-color var(--transition-fast), color var(--transition-fast);
			}
			.header-search-toggle:hover { border-color: var(--ink); color: var(--ink); }
			.header-search-toggle kbd {
				font-family: var(--font-mono);
				font-size: 10px;
				border: 1px solid var(--rule-2);
				padding: 2px 5px;
				border-radius: 3px;
				color: var(--ink-3);
			}

			/* Search overlay */
			.search-overlay {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(11, 20, 16, 0.55);
				z-index: 1000;
				align-items: flex-start;
				justify-content: center;
				padding-top: 15vh;
			}
			.search-overlay.active { display: flex; }

			.search-overlay-inner {
				background: var(--bg);
				border: 1px solid var(--rule);
				border-radius: var(--radius-lg);
				padding: var(--spacing-6);
				width: 90%;
				max-width: 600px;
				position: relative;
				box-shadow: 0 20px 60px rgba(0,0,0,0.15);
			}

			.search-close {
				position: absolute;
				top: 8px;
				right: 14px;
				background: none;
				border: none;
				font-size: 24px;
				cursor: pointer;
				color: var(--ink-3);
				line-height: 1;
			}
			.search-close:hover { color: var(--ink); }

			:global(.site-search) { width: 100%; }
			:global(.site-search-input) {
				width: 100%;
				padding: var(--spacing-3) var(--spacing-4);
				font-family: var(--font-sans);
				font-size: var(--font-size-lg);
				border: 1px solid var(--rule);
				border-radius: var(--radius-lg);
				background: var(--surface);
				color: var(--ink);
			}
			:global(.site-search-input)::placeholder { color: var(--ink-3); }
			:global(.site-search-input):focus,
			:global(.site-search-input):focus-visible {
				outline: none;
				border-color: var(--accent);
			}
			:global(.site-search-results) {
				margin-top: var(--spacing-2);
				background: var(--bg);
				border: 1px solid var(--rule);
				border-radius: var(--radius-lg);
				box-shadow: var(--shadow-dropdown);
				max-height: 400px;
				overflow-y: auto;
			}
			:global(.site-search-results .emdash-live-search-loading),
			:global(.site-search-results .emdash-live-search-no-results) {
				padding: var(--spacing-4);
				text-align: center;
				color: var(--ink-3);
				font-size: var(--font-size-sm);
			}
			:global(.site-search-result) {
				display: block;
				padding: var(--spacing-3) var(--spacing-4);
				text-decoration: none;
				color: var(--ink);
				border-bottom: 1px solid var(--rule);
			}
			:global(.site-search-result):last-child { border-bottom: none; }
			:global(.site-search-result):hover,
			:global(.site-search-result):focus,
			:global(.site-search-result.focused) { background: var(--surface); }
			:global(.site-search-result .emdash-live-search-result-title) {
				display: block;
				font-weight: 600;
				font-size: var(--font-size-sm);
			}
			:global(.site-search-result .emdash-live-search-result-collection) {
				display: block;
				font-family: var(--font-mono);
				font-size: 10px;
				color: var(--ink-3);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-top: 2px;
			}
			:global(.site-search-result .emdash-live-search-result-snippet) {
				display: block;
				font-size: var(--font-size-sm);
				color: var(--ink-3);
				margin-top: var(--spacing-1);
			}
			:global(.site-search-result .emdash-live-search-result-snippet mark) {
				font-weight: 600;
				color: var(--ink);
				background: var(--accent-soft);
			}

			/* Category nav */
			.cat-nav-wrap { border-top: 1px solid var(--rule); }
			.cat-nav {
				max-width: var(--maxw);
				margin: 0 auto;
				padding: 0 24px;
				display: flex;
				align-items: center;
				gap: 0;
				overflow-x: auto;
				scrollbar-width: none;
			}
			.cat-nav::-webkit-scrollbar { display: none; }
			.cat-nav a {
				padding: 12px 14px;
				font-size: 13px;
				font-weight: 500;
				color: var(--ink-2);
				white-space: nowrap;
				border-bottom: 2px solid transparent;
				margin-bottom: -1px;
				transition: color var(--transition-fast), border-color var(--transition-fast);
				display: flex;
				align-items: center;
				gap: 6px;
			}
			.cat-nav a:first-child { padding-left: 0; }
			.cat-nav a:hover { color: var(--accent); }
			.cat-nav a :global(svg) { width: 14px; height: 14px; }

			/* ===== FOOTER ===== */
			.site-footer {
				margin-top: var(--spacing-16);
				background: var(--surface);
				border-top: 1px solid var(--rule);
				padding: 48px 0 20px;
			}
			.footer-top {
				display: grid;
				grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr;
				gap: 32px;
				padding-bottom: 40px;
				border-bottom: 1px solid var(--rule);
				margin-bottom: 20px;
			}
			.footer-brand {
				display: flex;
				align-items: center;
				gap: 10px;
				margin-bottom: 14px;
			}
			.footer-brand img { height: 28px; width: auto; }
			.footer-brand strong {
				font-size: 14px;
				font-weight: 700;
				letter-spacing: -0.01em;
			}

			.footer-top h4 {
				font-family: var(--font-mono);
				font-size: 11px;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--ink-3);
				margin: 0 0 14px;
			}

			.footer-newsletter p {
				font-size: 14px;
				color: var(--ink-2);
				line-height: 1.5;
				margin: 0 0 16px;
				max-width: 340px;
			}
			.footer-newsletter .sub-row {
				display: flex;
				gap: 8px;
				max-width: 380px;
			}
			.footer-newsletter input {
				flex: 1;
				padding: 10px 14px;
				border: 1px solid var(--rule-2);
				border-radius: 999px;
				font: inherit;
				font-size: 13px;
				outline: none;
				background: var(--bg);
				color: var(--ink);
			}
			.footer-newsletter input:focus { border-color: var(--ink); }
			.footer-newsletter button {
				padding: 10px 18px;
				background: var(--accent);
				color: white;
				border: 0;
				border-radius: 999px;
				font-weight: 600;
				font-size: 13px;
				cursor: pointer;
				transition: background var(--transition-fast);
			}
			.footer-newsletter button:hover { background: var(--accent-2); }

			.footer-links {
				display: flex;
				flex-direction: column;
				gap: 8px;
				font-size: 13px;
			}
			.footer-links a { color: var(--ink-2); }
			.footer-links a:hover { color: var(--accent); }

			.footer-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 6px;
			}
			.footer-tag {
				display: inline-block;
				padding: 4px 10px;
				font-size: 12px;
				color: var(--ink-2);
				background: var(--bg);
				border: 1px solid var(--rule);
				border-radius: 999px;
				transition: color var(--transition-fast), border-color var(--transition-fast);
			}
			.footer-tag:hover { color: var(--accent); border-color: var(--accent); }

			.footer-bottom {
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-family: var(--font-mono);
				font-size: 11px;
				color: var(--ink-3);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}
			.footer-admin { color: var(--ink-3) !important; }
			.footer-admin:hover { color: var(--accent) !important; }

			/* Footer widget overrides */
			.footer-col :global(.widget-area) { display: block; }
			.footer-col :global(.widget__title) { display: none; }
			.footer-col :global(.widget__content) {
				color: var(--ink-2);
				font-size: 13px;
				line-height: 1.55;
			}

			/* ===== RESPONSIVE ===== */
			@media (max-width: 1100px) {
				.footer-top { grid-template-columns: 1.4fr 1fr 1fr; }
				.footer-top > :nth-child(n+4) { display: none; }
			}
			@media (max-width: 900px) {
				.header-main { grid-template-columns: auto 1fr auto; padding: 14px 16px; }
				.header-main-spacer { display: none; }
				.header-search-toggle span { display: none; }
				.header-search-toggle kbd { display: none; }
				.util-l { font-size: 10px; }
				.util-date { display: none; }
				.site-logo img { height: 40px; }
				.footer-top { grid-template-columns: 1fr; gap: 28px; }
				.footer-top > :nth-child(n+4) { display: block; }
				.footer-bottom { flex-direction: column; gap: 6px; text-align: center; }
			}
			@media (max-width: 640px) {
				.site-logo img { height: 36px; }
				.util-l span:not(.util-dot) { display: none; }
				.util-l::before {
					content: '';
					display: inline-block;
					width: 6px;
					height: 6px;
					border-radius: 50%;
					background: var(--accent);
					animation: pulse 2s infinite;
				}
			}
		</style>

		<!-- Shared CatIcon component for inline use in nav -->
		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
