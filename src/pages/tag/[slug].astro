---
import { getTerm, getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";

const { slug } = Astro.params;
const term = slug ? await getTerm("tag", slug) : null;

if (!term) {
	return Astro.redirect("/404");
}

const { entries: posts } = await getEmDashCollection("posts", {
	where: { tag: term.slug },
	orderBy: { published_at: "desc" },
});

const filteredPosts = await Promise.all(
	posts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		return {
			post,
			tags,
			bylines: post.data.bylines ?? [],
			readingTime: getReadingTime(post.data.content),
		};
	}),
);
---

<Base
	title={`Posts tagged "${term.label}"`}
	description={`All posts tagged with ${term.label}`}
>
	<section class="archive-hero">
		<div class="container">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Home</a>
				<span class="sep">/</span>
				<span>Tags</span>
			</nav>
			<span class="archive-kicker">Tag</span>
			<h1 class="archive-title">#{term.label}</h1>
			<p class="archive-count">
				{filteredPosts.length}
				{filteredPosts.length === 1 ? "story" : "stories"}
			</p>
		</div>
	</section>

	<section class="archive-body">
		<div class="container">
			{filteredPosts.length === 0 ? (
				<p class="no-posts">No stories with this tag yet.</p>
			) : (
				<div class="river">
					{filteredPosts.map(({ post, tags, bylines, readingTime }) => (
						<PostCard
							title={post.data.title}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={`/${post.id}`}
							date={post.data.publishedAt ?? undefined}
							readingTime={readingTime}
							tags={tags.map((t) => ({ slug: t.slug, label: t.label }))}
							bylines={bylines}
						/>
					))}
				</div>
			)}
		</div>
	</section>
</Base>

<style>
	.archive-hero {
		padding: 40px 0 28px;
		border-bottom: 1px solid var(--rule);
	}
	.breadcrumb {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 16px;
	}
	.breadcrumb a { color: var(--ink-3); }
	.breadcrumb a:hover { color: var(--accent); }
	.breadcrumb .sep { margin: 0 8px; color: var(--rule-2); }

	.archive-kicker {
		display: inline-block;
		background: var(--ink);
		color: var(--bg);
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding: 4px 8px;
		margin-bottom: 14px;
	}
	.archive-title {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(32px, 4.5vw, 56px);
		line-height: 1.02;
		letter-spacing: -0.032em;
		margin: 0 0 10px;
	}
	.archive-count {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin: 0;
	}

	.archive-body {
		padding: 40px 0 64px;
	}

	.river {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px 24px;
	}
	@media (max-width: 900px) {
		.river { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 600px) {
		.river { grid-template-columns: 1fr; }
	}

	.no-posts {
		color: var(--ink-3);
		font-size: 15px;
		padding: 32px 0;
	}
</style>
