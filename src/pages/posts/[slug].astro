		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: var(--radius-lg);
		margin-top: 24px;
		background: var(--bg-alt);
	}
	.hero-pic :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* ===== BODY ===== */
	.review-body {
		padding: 40px 24px 64px;
		display: grid;
		grid-template-columns: 240px minmax(0, 680px) 240px;
		gap: 40px;
		justify-content: center;
		align-items: start;
	}
	@media (max-width: 1000px) {
		.review-body {
			grid-template-columns: 1fr;
			padding: 32px 24px 48px;
		}
		.sticky-toc, .sticky-rail { display: none; }
	}

	.sticky-toc, .sticky-rail {
		position: sticky;
		top: 180px;
	}

	.sticky-toc h4 {
		font-family: var(--font-mono);
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		margin: 0 0 12px;
		font-weight: 600;
	}
	.sticky-toc ol {
		list-style: none;
		padding-left: 14px;
		margin: 0;
		border-left: 2px solid var(--rule);
	}
	.sticky-toc ol li {
		padding: 6px 0;
		font-size: 13px;
		line-height: 1.3;
		color: var(--ink-2);
		cursor: pointer;
	}
	.sticky-toc ol li.nested { padding-left: 12px; font-size: 12px; }
	.sticky-toc ol li:hover,
	.sticky-toc ol li.active {
		color: var(--accent);
		font-weight: 600;
	}

	.sticky-rail { display: flex; flex-direction: column; gap: 16px; }
	.rail-card {
		background: var(--surface);
		border: 1px solid var(--rule);
		border-radius: var(--radius-lg);
		padding: 16px 18px;
	}
	.rail-label {
		font-family: var(--font-mono);
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		font-weight: 600;
		margin-bottom: 10px;
	}
	.rail-author {
		display: flex;
		gap: 10px;
		align-items: flex-start;
	}
	.rail-avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: var(--accent);
		color: white;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		font-size: 12px;
		font-family: var(--font-mono);
		flex-shrink: 0;
	}
	.rail-author strong {
		font-weight: 600;
		font-size: 14px;
		color: var(--ink);
	}
	.rail-bio {
		font-size: 12px;
		color: var(--ink-3);
		line-height: 1.45;
		margin: 4px 0 0;
	}
	.rail-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}
	.rail-tag {
		display: inline-block;
		padding: 3px 10px;
		font-size: 11px;
		background: var(--bg);
		border: 1px solid var(--rule);
		border-radius: 999px;
		color: var(--ink-2);
		text-decoration: none;
	}
	.rail-tag:hover { color: var(--accent); border-color: var(--accent); }

	/* ===== PROSE ===== */
	.prose {
		font-size: 17px;
		line-height: 1.65;
		color: var(--ink);
	}
	.prose :global(p) {
		margin: 0 0 1.2em;
		color: var(--ink-2);
	}
	.prose :global(strong) { color: var(--ink); }
	.prose :global(h2) {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 26px;
		letter-spacing: -0.02em;
		margin: 2.4em 0 0.6em;
		padding-top: 0.4em;
		border-top: 2px solid var(--ink);
		color: var(--ink);
	}
	.prose :global(h3) {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 20px;
		letter-spacing: -0.015em;
		margin: 2em 0 0.5em;
		color: var(--ink);
	}
	.prose :global(blockquote) {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 22px;
		line-height: 1.3;
		letter-spacing: -0.015em;
		padding: 20px 0;
		border-top: 2px solid var(--accent);
		border-bottom: 2px solid var(--accent);
		color: var(--ink);
		margin: 2em 0;
	}
	.prose :global(ul),
	.prose :global(ol) {
		margin: 0 0 1.4em;
		padding-left: 1.4em;
		color: var(--ink-2);
	}
	.prose :global(li) { margin-bottom: 0.5em; }
	.prose :global(img) {
		margin: 2em 0;
		border-radius: var(--radius-lg);
	}
	.prose :global(hr) {
		margin: 3em 0;
		border: none;
		border-top: 1px solid var(--rule);
	}
	.prose :global(a) {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
	}
	.prose :global(a:hover) { text-decoration-thickness: 2px; }
	.prose :global(pre) {
		margin: 2em 0;
		padding: 20px;
		background: var(--surface);
		border: 1px solid var(--rule);
		border-radius: var(--radius-lg);
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: 13px;
		line-height: 1.6;
	}
	.prose :global(code) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		background: var(--bg-alt);
		padding: 0.15em 0.4em;
		border-radius: 3px;
	}
	.prose :global(pre code) { background: none; padding: 0; }

	/* ===== EXTRAS ===== */
	.article-extras {
		padding: 40px 0 64px;
		background: var(--surface);
		border-top: 1px solid var(--rule);
	}
	.extras-inner {
		display: block;
		padding-top: 0;
	}
	.extras-main { min-width: 0; }

	.article-comments {
		padding-bottom: 40px;
		margin-bottom: 40px;
		border-bottom: 1px solid var(--rule);
	}

	.more-posts { padding-top: 8px; }
	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding-bottom: 16px;
		margin-bottom: 20px;
		border-bottom: 2px solid var(--ink);
		gap: 16px;
		flex-wrap: wrap;
	}
	.section-head h2 {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 22px;
		letter-spacing: -0.02em;
		margin: 0;
	}
	.section-head h2 .sub { color: var(--accent); }
	.section-head a.viewall {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 600;
	}
	.section-head a.viewall:hover { color: var(--accent); }

