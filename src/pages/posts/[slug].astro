---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getSeoMeta,
} from "emdash";
import {
	Image,
	PortableText,
	CommentForm,
} from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import Sidebar from "../../components/Sidebar.astro";
import { getReadingTime } from "../../utils/reading-time";
import { getBylineAvatar } from "../../utils/gravatar";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

// If accessed directly (not via rewrite from catch-all),
// 301 redirect to the canonical root-level URL
if (!Astro.request.headers.get("X-Rewrite")) {
	return Astro.redirect(`/${slug}`, 301);
}

// Prefer the prefetched entry left by the catch-all (`/:slug`) to avoid a
// second D1 round-trip. Fall back to a direct query for any future route
// that hits this file without going through the catch-all.
const prefetched = Astro.locals.prefetchedEntry;
const { entry: post, cacheHint } =
	prefetched?.collection === "posts" && prefetched.slug === slug
		? (prefetched.result as Awaited<ReturnType<typeof getEmDashEntry<"posts">>>)
		: await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);

const seo = getSeoMeta(post, {
	siteTitle: "Practical Travel Gear",
	siteUrl: Astro.url.origin,
	path: `/${slug}`,
	defaultOgImage: featuredImageUrl,
});

// Fetch the post's own tags and the recent-posts list in parallel.
const [tags, { entries: recentPosts }] = await Promise.all([
	getEntryTerms("posts", post.data.id, "tag"),
	getEmDashCollection("posts", {
		orderBy: { published_at: "desc" },
		limit: 4,
	}),
]);
const bylines = post.data.bylines ?? [];
const readingTime = getReadingTime(post.data.content);

const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);
const otherPostsWithTags = await Promise.all(
	otherPosts.map(async (p) => {
		const postTags = await getEntryTerms("posts", p.data.id, "tag");
		return { post: p, tags: postTags, bylines: p.data.bylines ?? [] };
	})
);

const publishDate =
	post.data.publishedAt?.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	}) ?? null;

const authorName = bylines.length > 0 ? bylines[0].byline.displayName : null;
---

<Base
	title={seo.title}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<div class="post-layout">
		<div class="post-main">
			<article class="article">
				{post.data.featured_image && (
					<div class="article-hero" {...post.edit.featured_image}>
						<Image image={post.data.featured_image} />
					</div>
				)}

				<h1 class="article-title" {...post.edit.title}>{post.data.title}</h1>

				<div class="article-meta">
					{publishDate && <time>{publishDate}</time>}
					{publishDate && readingTime && <span class="meta-sep">&mdash;</span>}
					{readingTime && <span>{readingTime} Min Read</span>}
				</div>

				{post.data.excerpt && (
					<p class="article-excerpt">{post.data.excerpt}</p>
				)}

				<div class="article-content">
					<PortableText value={post.data.content} />
				</div>

				{tags.length > 0 && (
					<div class="article-tags">
						{tags.map((t) => (
							<a href={`/tag/${t.slug}`} class="article-tag">#{t.label}</a>
						))}
					</div>
				)}

				{authorName && (
					<div class="article-author">
						<img
							src={bylines[0].byline.avatarMediaId
								? `/_emdash/api/media/file/${bylines[0].byline.avatarMediaId}`
								: getBylineAvatar(bylines[0].byline.slug)}
							alt={authorName}
							class="author-avatar"
						/>
						<span class="author-name">{authorName}</span>
					</div>
				)}

				<div class="article-comments">
					<div
						class="comments-lazy"
						data-comments-root
						data-collection="posts"
						data-content-id={post.data.id}
					>
						<noscript>
							<p class="comments-noscript">Enable JavaScript to read comments.</p>
						</noscript>
					</div>
					<CommentForm collection="posts" contentId={post.data.id} />
				</div>
			</article>

			{otherPostsWithTags.length > 0 && (
				<section class="more-posts">
					<h2 class="more-title">Continue reading</h2>
					{otherPostsWithTags.map(
						({ post: p, tags: postTags, bylines: postBylines }) => (
							<PostCard
								title={p.data.title}
								excerpt={p.data.excerpt}
								featuredImage={p.data.featured_image}
								href={`/${p.id}`}
								date={p.data.publishedAt ?? undefined}
								readingTime={getReadingTime(p.data.content)}
								tags={postTags.map((t) => ({ slug: t.slug, label: t.label }))}
								bylines={postBylines}
							/>
						)
					)}
				</section>
			)}
		</div>

		<div class="post-sidebar">
			<Sidebar />
		</div>
	</div>
</Base>

<style>
	.post-layout {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-10) var(--spacing-6);
		display: grid;
		grid-template-columns: 1fr var(--sidebar-width);
		gap: var(--spacing-10);
		align-items: start;
	}

	.post-main {
		min-width: 0;
	}

	.post-sidebar {
		position: sticky;
		top: var(--spacing-10);
	}

	/* Article */
	.article-hero {
		border-radius: var(--radius-lg);
		overflow: hidden;
		margin-bottom: var(--spacing-8);
	}

	.article-hero img {
		width: 100%;
		height: auto;
		max-height: 500px;
		object-fit: cover;
	}

	.article-title {
		font-size: clamp(1.75rem, 4vw, var(--font-size-4xl));
		font-weight: 700;
		line-height: var(--leading-tight);
		margin-bottom: var(--spacing-3);
	}

	.article-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-6);
	}

	.meta-sep {
		color: var(--color-accent);
	}

	.article-excerpt {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-8);
		font-style: italic;
	}

	/* Article content typography */
	.article-content {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
	}

	.article-content :global(p) {
		margin-bottom: 1.5em;
	}

	.article-content :global(h2) {
		font-size: var(--font-size-2xl);
		margin-top: 2.5em;
		margin-bottom: 0.75em;
	}

	.article-content :global(h3) {
		font-size: var(--font-size-xl);
		margin-top: 2em;
		margin-bottom: 0.5em;
	}

	.article-content :global(blockquote) {
		margin: 2em 0;
		padding: var(--spacing-4) var(--spacing-6);
		border-left: 3px solid var(--color-accent);
		background: var(--color-surface);
		border-radius: 0 var(--radius) var(--radius) 0;
		color: var(--color-text-secondary);
		font-style: italic;
	}

	.article-content :global(pre) {
		margin: 2em 0;
		padding: var(--spacing-5);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		line-height: 1.6;
	}

	.article-content :global(code) {
		font-family: var(--font-mono);
		font-size: 0.9em;
		background: var(--color-surface);
		padding: 0.2em 0.4em;
		border-radius: var(--radius);
	}

	.article-content :global(pre code) {
		background: none;
		padding: 0;
	}

	.article-content :global(ul),
	.article-content :global(ol) {
		margin-bottom: 1.5em;
		padding-left: 1.5em;
	}

	.article-content :global(li) {
		margin-bottom: 0.5em;
	}

	.article-content :global(img) {
		margin: 2em 0;
		border-radius: var(--radius-lg);
	}

	.article-content :global(hr) {
		margin: 3em 0;
		border: none;
		border-top: 1px solid var(--color-border);
	}

	.article-content :global(a) {
		color: var(--color-accent);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
	}

	.article-content :global(a:hover) {
		text-decoration-thickness: 2px;
	}

	/* Tags */
	.article-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		margin-top: var(--spacing-8);
		padding-top: var(--spacing-6);
		border-top: 1px solid var(--color-border);
	}

	.article-tag {
		font-size: var(--font-size-sm);
		color: var(--color-tag);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.article-tag:hover {
		color: var(--color-accent);
	}

	/* Author */
	.article-author {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		margin-top: var(--spacing-6);
		padding: var(--spacing-4);
		background: var(--color-surface);
		border-radius: var(--radius-lg);
	}

	.author-avatar {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		object-fit: cover;
	}

	.author-name {
		font-weight: 600;
		color: var(--color-text);
	}

	/* Comments */
	.article-comments {
		margin-top: var(--spacing-12);
		padding-top: var(--spacing-8);
		border-top: 1px solid var(--color-border);
	}

	.article-comments :global(.ec-comments) {
		--ec-comment-border: 1px solid var(--color-border);
	}

	.article-comments :global(.ec-comments-heading) {
		font-size: var(--font-size-2xl);
		font-weight: 600;
		margin-bottom: var(--spacing-8);
	}

	.article-comments :global(.ec-comment-form-field input),
	.article-comments :global(.ec-comment-form-field textarea) {
		background: var(--color-surface) !important;
		border-color: var(--color-border) !important;
		color: var(--color-text) !important;
	}

	.article-comments :global(.ec-comment-form-submit) {
		background: var(--color-accent) !important;
		color: var(--color-on-accent) !important;
	}

	.comments-lazy {
		min-height: 80px;
	}

	.comments-lazy :global(.ec-comments-heading) {
		font-size: var(--font-size-2xl);
		font-weight: 600;
		margin-bottom: var(--spacing-8);
	}

	.comments-lazy :global(.ec-comments-list),
	.comments-lazy :global(.ec-comment-replies) {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.comments-lazy :global(.ec-comments-list > li + li) {
		margin-top: var(--spacing-6);
	}

	.comments-lazy :global(.ec-comment) {
		padding-bottom: var(--spacing-6);
		border-bottom: 1px solid var(--color-border);
	}

	.comments-lazy :global(.ec-comment-replies) {
		margin-top: var(--spacing-6);
		padding-left: var(--spacing-8);
	}

	.comments-lazy :global(.ec-comment-replies > li + li) {
		margin-top: var(--spacing-6);
	}

	.comments-lazy :global(.ec-comment-header) {
		display: flex;
		align-items: baseline;
		gap: var(--spacing-2);
		flex-wrap: wrap;
	}

	.comments-lazy :global(.ec-comment-author) {
		font-weight: 600;
	}

	.comments-lazy :global(.ec-comment-date) {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.comments-lazy :global(.ec-comment-body) {
		margin-top: var(--spacing-2);
		white-space: pre-wrap;
		word-break: break-word;
	}

	.comments-loading,
	.comments-empty,
	.comments-error {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
		padding: var(--spacing-4) 0;
	}

	.comments-noscript {
		color: var(--color-muted);
		font-size: var(--font-size-sm);
	}

	/* More posts */
	.more-posts {
		margin-top: var(--spacing-12);
		padding-top: var(--spacing-8);
		border-top: 1px solid var(--color-border);
	}

	.more-title {
		font-size: var(--font-size-2xl);
		font-weight: 600;
		margin-bottom: var(--spacing-8);
	}

	/* Responsive */
	@media (max-width: 900px) {
		.post-layout {
			grid-template-columns: 1fr;
		}

		.post-sidebar {
			position: static;
		}
	}

	@media (max-width: 600px) {
		.article-title {
			font-size: var(--font-size-2xl);
		}
	}
</style>

<script>
	type PublicComment = {
		id: string;
		authorName: string;
		isRegisteredUser?: boolean;
		createdAt: string;
		body: string;
		replies?: PublicComment[];
	};

	const URL_RE = /(https?:\/\/[^\s<>"')\]]+)/g;

	const fmtDate = (iso: string) => {
		const d = new Date(iso);
		if (isNaN(d.getTime())) return iso;
		return d.toLocaleDateString("en-US", {
			year: "numeric",
			month: "long",
			day: "numeric",
			hour: "numeric",
			minute: "2-digit",
		});
	};

	// Build a body element with URL auto-linking. User text goes through
	// textContent (no HTML parsing); anchors are constructed via createElement.
	const buildBody = (text: string): HTMLDivElement => {
		const div = document.createElement("div");
		div.className = "ec-comment-body";
		const parts = text.split(URL_RE);
		for (const part of parts) {
			if (URL_RE.test(part)) {
				URL_RE.lastIndex = 0;
				const a = document.createElement("a");
				a.href = part;
				a.rel = "nofollow ugc noopener";
				a.target = "_blank";
				a.textContent = part;
				div.appendChild(a);
			} else if (part) {
				div.appendChild(document.createTextNode(part));
			}
		}
		return div;
	};

	const buildComment = (c: PublicComment, isReply = false): HTMLElement => {
		const article = document.createElement("article");
		article.className = isReply ? "ec-comment ec-comment-reply" : "ec-comment";
		article.id = `comment-${c.id}`;
		article.dataset.commentId = c.id;

		const header = document.createElement("header");
		header.className = "ec-comment-header";

		const author = document.createElement("span");
		author.className = "ec-comment-author";
		author.textContent = c.authorName;
		if (c.isRegisteredUser) {
			const badge = document.createElement("span");
			badge.className = "ec-comment-badge";
			badge.setAttribute("aria-label", "Site member");
			badge.textContent = " \u2713";
			author.appendChild(badge);
		}
		header.appendChild(author);

		const time = document.createElement("time");
		time.className = "ec-comment-date";
		time.dateTime = c.createdAt;
		time.textContent = fmtDate(c.createdAt);
		header.appendChild(time);

		article.appendChild(header);
		article.appendChild(buildBody(c.body));

		if (c.replies && c.replies.length > 0) {
			const ol = document.createElement("ol");
			ol.className = "ec-comment-replies";
			for (const reply of c.replies) {
				const li = document.createElement("li");
				li.appendChild(buildComment(reply, true));
				ol.appendChild(li);
			}
			article.appendChild(ol);
		}

		return article;
	};

	const setMessage = (root: HTMLElement, text: string, cls: string) => {
		root.replaceChildren();
		const div = document.createElement("div");
		div.className = cls;
		div.textContent = text;
		root.appendChild(div);
	};

	const load = async (root: HTMLElement) => {
		const collection = root.dataset.collection;
		const contentId = root.dataset.contentId;
		if (!collection || !contentId) return;

		setMessage(root, "Loading comments\u2026", "comments-loading");

		const url = `/_emdash/api/comments/${encodeURIComponent(collection)}/${encodeURIComponent(
			contentId,
		)}?threaded=true`;

		try {
			const res = await fetch(url);
			if (res.status === 403) {
				root.replaceChildren();
				return;
			}
			if (!res.ok) throw new Error(`HTTP ${res.status}`);
			const payload = (await res.json()) as {
				success: boolean;
				data?: { items: PublicComment[]; total: number };
			};
			if (!payload.success || !payload.data) throw new Error("Bad response");

			const { items, total } = payload.data;
			const section = document.createElement("section");
			section.className = "ec-comments";
			section.dataset.collection = collection;
			section.dataset.contentId = contentId;

			const heading = document.createElement("h3");
			heading.className = "ec-comments-heading";
			heading.textContent =
				total === 0
					? "No comments yet"
					: total === 1
						? "1 Comment"
						: `${total} Comments`;
			section.appendChild(heading);

			if (items.length > 0) {
				const list = document.createElement("ol");
				list.className = "ec-comments-list";
				for (const c of items) {
					const li = document.createElement("li");
					li.appendChild(buildComment(c));
					list.appendChild(li);
				}
				section.appendChild(list);
			}

			root.replaceChildren(section);
		} catch (err) {
			setMessage(root, "Could not load comments.", "comments-error");
			console.error("[comments] load failed:", err);
		}
	};

	const roots = document.querySelectorAll<HTMLElement>("[data-comments-root]");
	if (roots.length > 0) {
		if ("IntersectionObserver" in window) {
			const io = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						if (entry.isIntersecting) {
							io.unobserve(entry.target);
							load(entry.target as HTMLElement);
						}
					}
				},
				{ rootMargin: "400px" },
			);
			roots.forEach((r) => io.observe(r));
		} else {
			roots.forEach((r) => load(r));
		}
	}
</script>
