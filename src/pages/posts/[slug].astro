---
import {
	getEmDashEntry,
	getEmDashCollection,
	getEntryTerms,
	getSeoMeta,
} from "emdash";
import { Image, PortableText, CommentForm } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";
import { getBylineAvatar } from "../../utils/gravatar";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

// If accessed directly (not via rewrite from catch-all),
// 301 redirect to the canonical root-level URL
if (!Astro.request.headers.get("X-Rewrite")) {
	return Astro.redirect(`/${slug}`, 301);
}

const prefetched = Astro.locals.prefetchedEntry;
const { entry: post, cacheHint } =
	prefetched?.collection === "posts" && prefetched.slug === slug
		? (prefetched.result as Awaited<ReturnType<typeof getEmDashEntry<"posts">>>)
		: await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(post.data.featured_image);

const seo = getSeoMeta(post, {
	siteTitle: "Practical Travel Gear",
	siteUrl: Astro.url.origin,
	path: `/${slug}`,
	defaultOgImage: featuredImageUrl,
});

// Fetch post metadata + recent posts for "Continue reading" in parallel.
const [tags, categories, { entries: recentPosts }] = await Promise.all([
	getEntryTerms("posts", post.data.id, "tag"),
	getEntryTerms("posts", post.data.id, "category"),
	getEmDashCollection("posts", {
		orderBy: { published_at: "desc" },
		limit: 4,
	}),
]);
const bylines = post.data.bylines ?? [];
const readingTime = getReadingTime(post.data.content);

const otherPosts = recentPosts.filter((p) => p.id !== post.id).slice(0, 3);
const otherPostsWithTags = await Promise.all(
	otherPosts.map(async (p) => {
		const postTags = await getEntryTerms("posts", p.data.id, "tag");
		return { post: p, tags: postTags, bylines: p.data.bylines ?? [] };
	}),
);

const publishDate =
	post.data.publishedAt?.toLocaleDateString("en-US", {
		month: "short",
		day: "numeric",
		year: "numeric",
	}) ?? null;

const primaryCategory = categories[0] ?? null;
const primaryAuthor = bylines[0]?.byline ?? null;
const primaryAuthorInitials = primaryAuthor
	? primaryAuthor.displayName
			.split(" ")
			.map((w) => w[0])
			.filter(Boolean)
			.slice(0, 2)
			.join("")
			.toUpperCase()
	: null;
---

<Base
	title={seo.title}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={post.data.publishedAt?.toISOString() ?? null}
	modifiedTime={post.data.updatedAt.toISOString()}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<article class="review">
		{/* ===== HERO ===== */}
		<section class="review-hero">
			<div class="container">
				<nav class="breadcrumb" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span class="sep">/</span>
					<a href="/posts">Posts</a>
					{primaryCategory && (
						<>
							<span class="sep">/</span>
							<a href={`/category/${primaryCategory.slug}`}>
								{primaryCategory.label}
							</a>
						</>
					)}
				</nav>

				{primaryCategory && (
					<span class="cat-chip filled">{primaryCategory.label}</span>
				)}

				<h1 class="review-title" {...post.edit.title}>{post.data.title}</h1>

				{post.data.excerpt && (
					<p class="dek">{post.data.excerpt}</p>
				)}

				<div class="meta-row">
					{primaryAuthor && (
						<div class="author">
							<img
								src={primaryAuthor.avatarMediaId
									? `/_emdash/api/media/file/${primaryAuthor.avatarMediaId}`
									: getBylineAvatar(primaryAuthor.slug)}
								alt={primaryAuthor.displayName}
								class="author-avatar"
							/>
							<span>
								By <strong>{primaryAuthor.displayName}</strong>
							</span>
						</div>
					)}
					{publishDate && <span>{publishDate}</span>}
					{readingTime && <span>{readingTime} min read</span>}
				</div>

				{post.data.featured_image && (
					<div class="hero-pic" {...post.edit.featured_image}>
						<Image image={post.data.featured_image} />
					</div>
				)}
			</div>
		</section>

		{/* ===== BODY ===== */}
		<section>
			<div class="container review-body">
				<aside class="sticky-toc" aria-label="Table of contents">
					<h4>In this article</h4>
					<ol id="toc-content">
						<!-- populated by JS -->
					</ol>
				</aside>

				<div class="prose">
					<PortableText value={post.data.content} />
				</div>

				<aside class="sticky-rail">
					{primaryAuthor && (
						<div class="rail-card">
							<div class="rail-label">Written by</div>
							<div class="rail-author">
								{primaryAuthorInitials && (
									<div class="rail-avatar">{primaryAuthorInitials}</div>
								)}
								<div>
									<strong>{primaryAuthor.displayName}</strong>
									{primaryAuthor.bio && (
										<p class="rail-bio">{primaryAuthor.bio}</p>
									)}
								</div>
							</div>
						</div>
					)}
					{tags.length > 0 && (
						<div class="rail-card">
							<div class="rail-label">Topics</div>
							<div class="rail-tags">
								{tags.map((t) => (
									<a href={`/tag/${t.slug}`} class="rail-tag">{t.label}</a>
								))}
							</div>
						</div>
					)}
				</aside>
			</div>
		</section>

		{/* ===== COMMENTS + CONTINUE READING ===== */}
		<section class="article-extras">
			<div class="container extras-inner">
				<div class="extras-main">
					<div class="article-comments">
						<div
							class="comments-lazy"
							data-comments-root
							data-collection="posts"
							data-content-id={post.data.id}
						>
							<noscript>
								<p class="comments-noscript">Enable JavaScript to read comments.</p>
							</noscript>
						</div>
						<CommentForm collection="posts" contentId={post.data.id} />
					</div>

					{otherPostsWithTags.length > 0 && (
						<div class="more-posts">
							<div class="section-head">
								<h2>Continue <span class="sub">Reading</span></h2>
								<a class="viewall" href="/posts">All posts →</a>
							</div>
							<div class="river">
								{otherPostsWithTags.map(
									({ post: p, tags: postTags, bylines: postBylines }) => (
										<PostCard
											title={p.data.title}
											excerpt={p.data.excerpt}
											featuredImage={p.data.featured_image}
											href={`/${p.id}`}
											date={p.data.publishedAt ?? undefined}
											readingTime={getReadingTime(p.data.content)}
											tags={postTags.map((t) => ({
												slug: t.slug,
												label: t.label,
											}))}
											bylines={postBylines}
										/>
									),
								)}
							</div>
						</div>
					)}
				</div>
			</div>
		</section>
	</article>

	<script>
		function buildToc() {
			const content = document.querySelector(".prose");
			const container = document.getElementById("toc-content");
			const panel = document.querySelector(".sticky-toc") as HTMLElement | null;
			if (!content || !container || !panel) return;

			const headings = content.querySelectorAll("h2, h3");
			if (headings.length < 2) {
				panel.style.display = "none";
				return;
			}

			headings.forEach((h, i) => {
				if (!h.id) h.id = `heading-${i}`;
				const li = document.createElement("li");
				li.dataset.target = h.id;
				if (h.tagName === "H3") li.classList.add("nested");
				li.textContent = h.textContent;
				container.appendChild(li);
				li.addEventListener("click", () => {
					document.getElementById(h.id)?.scrollIntoView({ behavior: "smooth", block: "start" });
				});
			});

			const io = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.id;
						const li = container.querySelector(`li[data-target="${id}"]`);
						if (!li) return;
						if (entry.isIntersecting) {
							container.querySelectorAll("li").forEach((x) => x.classList.remove("active"));
							li.classList.add("active");
						}
					});
				},
				{ rootMargin: "-80px 0px -70% 0px" },
			);
			headings.forEach((h) => io.observe(h));
		}
		buildToc();
	</script>
</Base>

<style>
	.review { display: block; }

	/* ===== HERO ===== */
	.review-hero {
		padding: 32px 0 28px;
		border-bottom: 1px solid var(--rule);
	}
	.breadcrumb {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 16px;
	}
	.breadcrumb a { color: var(--ink-3); }
	.breadcrumb a:hover { color: var(--accent); }
	.breadcrumb .sep { margin: 0 8px; color: var(--rule-2); }

	.cat-chip.filled {
		display: inline-block;
		background: var(--ink);
		color: var(--bg);
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding: 4px 8px;
		margin-bottom: 14px;
	}

	.review-title {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(30px, 4.2vw, 52px);
		line-height: 1.05;
		letter-spacing: -0.028em;
		margin: 0 0 14px;
		max-width: 1000px;
	}
	.dek {
		font-size: 17px;
		color: var(--ink-2);
		line-height: 1.5;
		max-width: 760px;
		margin: 0 0 24px;
	}

	.meta-row {
		display: flex;
		gap: 24px;
		align-items: center;
		padding: 14px 0;
		border-top: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule);
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		flex-wrap: wrap;
	}
	.meta-row .author {
		display: flex;
		align-items: center;
		gap: 10px;
		color: var(--ink-2);
	}
	.meta-row .author-avatar {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		object-fit: cover;
	}
