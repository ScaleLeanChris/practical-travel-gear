---
import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";

const cursor = Astro.url.searchParams.get("cursor") ?? undefined;

const { entries: posts, nextCursor, cacheHint } = await getEmDashCollection(
	"posts",
	{
		limit: 21,
		cursor,
		orderBy: { published_at: "desc" },
	},
);

Astro.cache.set(cacheHint);

const postsWithMeta = await Promise.all(
	posts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		return {
			post,
			tags,
			bylines: post.data.bylines ?? [],
			readingTime: getReadingTime(post.data.content),
		};
	}),
);
---

<Base
	title="All Posts"
	description="Every review, dispatch, and travel note — in one place."
>
	<section class="archive-hero">
		<div class="container">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Home</a>
				<span class="sep">/</span>
				<span>Posts</span>
			</nav>
			<span class="archive-kicker">Index</span>
			<h1 class="archive-title">Latest Stories</h1>
			<p class="dek">
				Reviews, dispatches, and travel notes. Updated daily. Tested on the
				road.
			</p>
		</div>
	</section>

	<section class="archive-body">
		<div class="container">
			{posts.length === 0 ? (
				<p class="no-posts">No posts yet.</p>
			) : (
				<div class="river">
					{postsWithMeta.map(({ post, tags, bylines, readingTime }) => (
						<PostCard
							title={post.data.title ?? "Untitled"}
							excerpt={post.data.excerpt}
							featuredImage={post.data.featured_image}
							href={`/${post.id}`}
							date={post.data.publishedAt ?? undefined}
							readingTime={readingTime}
							tags={tags.map((t) => ({ slug: t.slug, label: t.label }))}
							bylines={bylines}
						/>
					))}
				</div>
			)}

			{nextCursor && (
				<div class="pagination">
					<a href={`/posts?cursor=${nextCursor}`} class="page-link">
						Older stories →
					</a>
				</div>
			)}
		</div>
	</section>
</Base>

<style>
	.archive-hero {
		padding: 40px 0 28px;
		border-bottom: 1px solid var(--rule);
	}
	.breadcrumb {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 16px;
	}
	.breadcrumb a { color: var(--ink-3); }
	.breadcrumb a:hover { color: var(--accent); }
	.breadcrumb .sep { margin: 0 8px; color: var(--rule-2); }

	.archive-kicker {
		display: inline-block;
		background: var(--ink);
		color: var(--bg);
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding: 4px 8px;
		margin-bottom: 14px;
	}
	.archive-title {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(32px, 4.5vw, 56px);
		line-height: 1.02;
		letter-spacing: -0.032em;
		margin: 0 0 14px;
		max-width: 900px;
	}
	.dek {
		font-size: 18px;
		color: var(--ink-2);
		line-height: 1.5;
		max-width: 720px;
		margin: 0;
	}

	.archive-body {
		padding: 40px 0 64px;
	}

	.river {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px 24px;
	}
	@media (max-width: 900px) {
		.river { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 600px) {
		.river { grid-template-columns: 1fr; }
	}

	.pagination {
		display: flex;
		justify-content: center;
		padding: 48px 0 0;
	}
	.page-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 10px 20px;
		background: var(--ink);
		color: var(--bg);
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		border-radius: 999px;
		text-decoration: none;
		transition: background var(--transition-fast);
	}
	.page-link:hover { background: var(--accent); }

	.no-posts {
		color: var(--ink-3);
		font-size: 15px;
		padding: 32px 0;
	}
</style>
