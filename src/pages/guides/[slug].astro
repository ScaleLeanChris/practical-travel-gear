---
import {
	getEmDashEntry,
	getEntryTerms,
	getSeoMeta,
} from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { getReadingTime } from "../../utils/reading-time";
import { getBylineAvatar } from "../../utils/gravatar";

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: guide, cacheHint } = await getEmDashEntry("guides", slug);

if (!guide) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);

function getImageUrl(img: unknown): string | undefined {
	if (!img || typeof img !== "object") return undefined;
	const image = img as Record<string, unknown>;
	if (typeof image.src === "string" && image.src) {
		return image.src.startsWith("http")
			? image.src
			: `${Astro.url.origin}${image.src}`;
	}
	const meta = image.meta as Record<string, unknown> | undefined;
	const storageKey =
		(typeof meta?.storageKey === "string" ? meta.storageKey : undefined) ||
		(typeof image.id === "string" ? image.id : undefined);
	if (storageKey) {
		return `${Astro.url.origin}/_emdash/api/media/file/${storageKey}`;
	}
	return undefined;
}
const featuredImageUrl = getImageUrl(guide.data.featured_image);

const seo = getSeoMeta(guide, {
	siteTitle: "Practical Travel Gear",
	siteUrl: Astro.url.origin,
	path: `/guides/${slug}`,
	defaultOgImage: featuredImageUrl,
});

const [tags, categories] = await Promise.all([
	getEntryTerms("guides", guide.data.id, "tag"),
	getEntryTerms("guides", guide.data.id, "category"),
]);

const bylines = guide.data.bylines ?? [];
const readingTime = getReadingTime(guide.data.content);

const publishDate =
	guide.data.publishedAt?.toLocaleDateString("en-US", {
		month: "short",
		day: "numeric",
		year: "numeric",
	}) ?? null;

const primaryCategory = categories[0] ?? null;

// Author initials for the avatar circles in the hero.
const authorList = bylines.map((credit) => {
	const name = credit.byline.displayName;
	const initials = name
		.split(" ")
		.map((w) => w[0])
		.filter(Boolean)
		.slice(0, 2)
		.join("")
		.toUpperCase();
	return {
		name,
		slug: credit.byline.slug,
		initials,
		role: credit.roleLabel ?? null,
		avatar: credit.byline.avatarMediaId
			? `/_emdash/api/media/file/${credit.byline.avatarMediaId}`
			: getBylineAvatar(credit.byline.slug),
	};
});
---

<Base
	title={seo.title}
	description={seo.description}
	image={seo.ogImage}
	canonical={seo.canonical}
	robots={seo.robots}
	type="article"
	publishedTime={guide.data.publishedAt?.toISOString() ?? null}
	modifiedTime={guide.data.updatedAt.toISOString()}
	content={{ collection: "guides", id: guide.data.id, slug }}
>
	<article class="guide">
		{/* ===== HERO ===== */}
		<section class="bg-hero">
			<div class="container">
				<nav class="breadcrumb" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span class="sep">/</span>
					<a href="/guides">Guides</a>
					{primaryCategory && (
						<>
							<span class="sep">/</span>
							<a href={`/category/${primaryCategory.slug}`}>
								{primaryCategory.label}
							</a>
						</>
					)}
				</nav>

				<span class="cat-chip filled">
					Guide{primaryCategory ? ` · ${primaryCategory.label}` : ""}
				</span>

				<h1 class="bg-title" {...guide.edit.title}>{guide.data.title}</h1>

				{guide.data.excerpt && (
					<p class="dek">{guide.data.excerpt}</p>
				)}

				<div class="authors">
					{authorList.map((a) => (
						<div class="author">
							<img src={a.avatar} alt={a.name} class="author-avatar" />
							<div>
								<strong>{a.name}</strong>
								{a.role && <div class="role">{a.role}</div>}
							</div>
						</div>
					))}
					<div class="stats">
						{publishDate && (
							<div class="stat">
								<div class="v">{publishDate}</div>
								<div class="l">Updated</div>
							</div>
						)}
						{readingTime && (
							<div class="stat">
								<div class="v">{readingTime}</div>
								<div class="l">Min Read</div>
							</div>
						)}
					</div>
				</div>
			</div>
		</section>

		{/* ===== BODY ===== */}
		<section>
			<div class="container bg-body">
				<aside class="toc" aria-label="Table of contents">
					<h4>On this page</h4>
					<ol id="toc-content">
						<!-- Populated by JS -->
					</ol>
				</aside>

				<div class="guide-main">
					{guide.data.featured_image && (
						<div class="bg-hero-pic" {...guide.edit.featured_image}>
							<Image image={guide.data.featured_image} />
						</div>
					)}
					<div class="prose">
						<PortableText value={guide.data.content} />
					</div>

					{tags.length > 0 && (
						<div class="guide-tags">
							<span class="tags-label">Tagged</span>
							{tags.map((t) => (
								<a href={`/tag/${t.slug}`} class="guide-tag">{t.label}</a>
							))}
						</div>
					)}
				</div>
			</div>
		</section>
	</article>

	<script>
		function buildToc() {
			const main = document.querySelector(".guide-main .prose");
			const container = document.getElementById("toc-content");
			const panel = document.querySelector(".toc") as HTMLElement | null;
			if (!main || !container || !panel) return;

			const headings = main.querySelectorAll("h2, h3");
			if (headings.length < 2) {
				panel.style.display = "none";
				return;
			}

			headings.forEach((h, i) => {
				if (!h.id) h.id = `heading-${i}`;
				const li = document.createElement("li");
				li.dataset.target = h.id;
				if (h.tagName === "H3") li.classList.add("nested");
				li.textContent = h.textContent;
				container.appendChild(li);
				li.addEventListener("click", () => {
					document.getElementById(h.id)?.scrollIntoView({ behavior: "smooth", block: "start" });
				});
			});

			const io = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const id = entry.target.id;
						const li = container.querySelector(`li[data-target="${id}"]`);
						if (!li) return;
						if (entry.isIntersecting) {
							container.querySelectorAll("li").forEach((x) => x.classList.remove("active"));
							li.classList.add("active");
						}
					});
				},
				{ rootMargin: "-80px 0px -70% 0px" },
			);
			headings.forEach((h) => io.observe(h));
		}
		buildToc();
	</script>
</Base>

<style>
	/* ===== HERO ===== */
	.bg-hero {
		padding: 40px 0 32px;
		border-bottom: 1px solid var(--rule);
	}
	.breadcrumb {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 20px;
	}
	.breadcrumb a { color: var(--ink-3); }
	.breadcrumb a:hover { color: var(--accent); }
	.breadcrumb .sep { margin: 0 8px; color: var(--rule-2); }

	.cat-chip.filled {
		display: inline-block;
		background: var(--ink);
		color: var(--bg);
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding: 4px 8px;
		margin-bottom: 16px;
	}

	.bg-title {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(32px, 4.5vw, 56px);
		line-height: 1.02;
		letter-spacing: -0.032em;
		margin: 0 0 16px;
		max-width: 900px;
	}
	.dek {
		font-size: 18px;
		color: var(--ink-2);
		line-height: 1.5;
		max-width: 720px;
		margin: 0 0 24px;
	}

	.authors {
		display: flex;
		align-items: center;
		gap: 20px;
		padding: 16px 0;
		border-top: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule);
		flex-wrap: wrap;
	}
	.author {
		display: flex;
		align-items: center;
		gap: 10px;
		font-size: 13px;
	}
	.author-avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		object-fit: cover;
	}
	.author strong {
		font-weight: 600;
		color: var(--ink);
	}
	.author .role {
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-top: 2px;
	}
	.stats {
		display: flex;
		gap: 32px;
		margin-left: auto;
	}
	.stats .stat .v {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 18px;
		letter-spacing: -0.015em;
		color: var(--ink);
	}
	.stats .stat .l {
		font-family: var(--font-mono);
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		margin-top: 2px;
	}

	/* ===== BODY ===== */
	.bg-body {
		padding: 32px 24px 64px;
		display: grid;
		grid-template-columns: 240px minmax(0, 820px);
		gap: 48px;
		justify-content: center;
		align-items: start;
	}
	@media (max-width: 1000px) {
		.bg-body {
			grid-template-columns: 1fr;
			padding: 32px 24px 48px;
		}
		.toc { display: none; }
	}

	.toc {
		position: sticky;
		top: 180px;
		border-left: 2px solid var(--rule);
		padding: 4px 0 4px 16px;
	}
	.toc h4 {
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		margin: 0 0 12px;
	}
	.toc ol {
		list-style: none;
		padding: 0;
		margin: 0;
		counter-reset: toc;
	}
	.toc ol li {
		counter-increment: toc;
		padding: 6px 0;
		font-size: 13px;
		line-height: 1.3;
		color: var(--ink-2);
		cursor: pointer;
		display: flex;
		gap: 8px;
	}
	.toc ol li.nested {
		padding-left: 24px;
		font-size: 12px;
	}
	.toc ol li::before {
		content: counter(toc, decimal-leading-zero);
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--ink-3);
		font-weight: 600;
		min-width: 20px;
	}
	.toc ol li:hover,
	.toc ol li.active {
		color: var(--accent);
		font-weight: 600;
	}

	.guide-main { min-width: 0; }

	.bg-hero-pic {
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: var(--radius-lg);
		background: var(--bg-alt);
		margin-bottom: 40px;
	}
	.bg-hero-pic :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* ===== PROSE ===== */
	.prose {
		font-size: 17px;
		line-height: 1.65;
		color: var(--ink);
	}
	.prose :global(p) {
		margin: 0 0 1.2em;
		color: var(--ink-2);
	}
	.prose :global(strong) { color: var(--ink); }
	.prose :global(h2) {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 28px;
		letter-spacing: -0.02em;
		margin: 2.4em 0 0.6em;
		padding-top: 0.4em;
		border-top: 2px solid var(--ink);
		color: var(--ink);
		scroll-margin-top: 160px;
	}
	.prose :global(h3) {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 22px;
		letter-spacing: -0.015em;
		margin: 2em 0 0.5em;
		color: var(--ink);
		scroll-margin-top: 160px;
	}
	.prose :global(blockquote) {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 22px;
		line-height: 1.3;
		letter-spacing: -0.015em;
		padding: 20px 0;
		border-top: 2px solid var(--accent);
		border-bottom: 2px solid var(--accent);
		color: var(--ink);
		margin: 2em 0;
	}
	.prose :global(ul),
	.prose :global(ol) {
		margin: 0 0 1.4em;
		padding-left: 1.4em;
		color: var(--ink-2);
	}
	.prose :global(li) { margin-bottom: 0.5em; }
	.prose :global(img) {
		margin: 2em 0;
		border-radius: var(--radius-lg);
	}
	.prose :global(hr) {
		margin: 3em 0;
		border: none;
		border-top: 1px solid var(--rule);
	}
	.prose :global(a) {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
	}
	.prose :global(a:hover) { text-decoration-thickness: 2px; }

	/* Tags footer */
	.guide-tags {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px;
		margin-top: 48px;
		padding-top: 24px;
		border-top: 1px solid var(--rule);
	}
	.tags-label {
		font-family: var(--font-mono);
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		font-weight: 600;
		margin-right: 6px;
	}
	.guide-tag {
		display: inline-block;
		padding: 4px 12px;
		font-size: 12px;
		background: var(--surface);
		border: 1px solid var(--rule);
		border-radius: 999px;
		color: var(--ink-2);
		text-decoration: none;
		transition: color var(--transition-fast), border-color var(--transition-fast);
	}
	.guide-tag:hover { color: var(--accent); border-color: var(--accent); }

	@media (max-width: 600px) {
		.bg-title { font-size: 30px; }
		.stats { gap: 16px; margin-left: 0; width: 100%; }
	}
</style>
