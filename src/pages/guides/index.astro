---
import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import { getReadingTime } from "../../utils/reading-time";

const { entries: guides, cacheHint } = await getEmDashCollection("guides", {
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

const guidesWithMeta = await Promise.all(
	guides.map(async (guide) => {
		const tags = await getEntryTerms("guides", guide.data.id, "tag");
		return {
			guide,
			tags,
			bylines: guide.data.bylines ?? [],
			readingTime: getReadingTime(guide.data.content),
		};
	}),
);
---

<Base
	title="Buyer's Guides"
	description="In-depth travel gear buying guides. Tested on the road."
>
	<section class="archive-hero">
		<div class="container">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Home</a>
				<span class="sep">/</span>
				<span>Guides</span>
			</nav>
			<span class="archive-kicker">Buyer's Guides</span>
			<h1 class="archive-title">In-depth gear guides.</h1>
			<p class="dek">
				Cut through the marketing. Every guide is tested, ranked, and
				independently written.
				{guides.length > 0 && (
					<span class="count-note">
						{" "}· {guides.length} {guides.length === 1 ? "guide" : "guides"} available
					</span>
				)}
			</p>
		</div>
	</section>

	<section class="archive-body">
		<div class="container">
			{guides.length === 0 ? (
				<p class="no-posts">No guides yet.</p>
			) : (
				<div class="river">
					{guidesWithMeta.map(({ guide, tags, bylines, readingTime }) => (
						<PostCard
							title={guide.data.title ?? "Untitled"}
							excerpt={guide.data.excerpt}
							featuredImage={guide.data.featured_image}
							href={`/guides/${guide.id}`}
							date={guide.data.publishedAt ?? undefined}
							readingTime={readingTime}
							tags={tags.map((t) => ({ slug: t.slug, label: t.label }))}
							bylines={bylines}
							kicker="Guide"
							variant="feature"
						/>
					))}
				</div>
			)}
		</div>
	</section>
</Base>

<style>
	.archive-hero {
		padding: 40px 0 28px;
		border-bottom: 1px solid var(--rule);
	}
	.breadcrumb {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-bottom: 16px;
	}
	.breadcrumb a { color: var(--ink-3); }
	.breadcrumb a:hover { color: var(--accent); }
	.breadcrumb .sep { margin: 0 8px; color: var(--rule-2); }

	.archive-kicker {
		display: inline-block;
		background: var(--accent);
		color: white;
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding: 4px 8px;
		margin-bottom: 14px;
	}
	.archive-title {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(32px, 4.5vw, 56px);
		line-height: 1.02;
		letter-spacing: -0.032em;
		margin: 0 0 14px;
		max-width: 900px;
	}
	.dek {
		font-size: 18px;
		color: var(--ink-2);
		line-height: 1.5;
		max-width: 720px;
		margin: 0;
	}
	.count-note {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.archive-body {
		padding: 40px 0 64px;
	}

	.river {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 40px 28px;
	}
	@media (max-width: 900px) {
		.river { grid-template-columns: 1fr; }
	}

	.no-posts {
		color: var(--ink-3);
		font-size: 15px;
		padding: 32px 0;
	}
</style>
