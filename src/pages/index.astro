---
import { getEmDashCollection, getEntryTerms } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime } from "../utils/reading-time";

const [
	{ entries: posts, cacheHint },
	{ entries: guides },
] = await Promise.all([
	getEmDashCollection("posts", {
		limit: 12,
		orderBy: { published_at: "desc" },
	}),
	getEmDashCollection("guides", {
		limit: 3,
		orderBy: { published_at: "desc" },
	}),
]);

Astro.cache.set(cacheHint);

// Fetch tags for all posts in parallel to avoid waterfall.
const postsWithTags = await Promise.all(
	posts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		return {
			post,
			tags: tags.map((t) => ({ slug: t.slug, label: t.label })),
			bylines: post.data.bylines ?? [],
			readingTime: getReadingTime(post.data.content),
		};
	}),
);

const guidesWithMeta = await Promise.all(
	guides.map(async (guide) => {
		const tags = await getEntryTerms("guides", guide.data.id, "tag");
		return {
			guide,
			tags,
			readingTime: getReadingTime(guide.data.content),
		};
	}),
);

// Split posts into layout regions
const heroLead = postsWithTags[0];
const heroStack = postsWithTags.slice(1, 4);
const featureStory = postsWithTags[4];
const riverPosts = postsWithTags.slice(5, 9);

function fmtDate(d: Date | null | undefined) {
	return d
		? d.toLocaleDateString("en-US", {
				month: "short",
				day: "numeric",
				year: "numeric",
			})
		: "";
}
---

<Base
	title="Honest Travel Gear Reviews and Advice"
	description="Honest travel gear reviews, practical buying advice, and tested recommendations for luggage, accessories, clothing, and outdoor essentials."
>
	{/* ===== HERO ===== */}
	{heroLead && (
		<section class="hero">
			<div class="container">
				<div class="hero-grid">
					<a class="hero-lead" href={`/${heroLead.post.id}`}>
						<div class="hero-lead-pic">
							{heroLead.post.data.featured_image && (
								<Image image={heroLead.post.data.featured_image} />
							)}
						</div>
						<div class="overlay">
							{heroLead.tags[0] && (
								<span class="cat">Featured · {heroLead.tags[0].label}</span>
							)}
							<h1>{heroLead.post.data.title}</h1>
							{heroLead.post.data.excerpt && (
								<p class="dek">{heroLead.post.data.excerpt}</p>
							)}
							<div class="meta">
								{heroLead.bylines[0] && (
									<span>
										By <strong>{heroLead.bylines[0].byline.displayName}</strong>
									</span>
								)}
								{heroLead.post.data.publishedAt && (
									<span>{fmtDate(heroLead.post.data.publishedAt)}</span>
								)}
								{heroLead.readingTime && (
									<span>{heroLead.readingTime} min read</span>
								)}
							</div>
						</div>
					</a>

					<div class="hero-stack">
						{heroStack.map(({ post, tags, bylines, readingTime }) => (
							<a class="hero-stack-item" href={`/${post.id}`}>
								<div class="pic">
									{post.data.featured_image && (
										<Image image={post.data.featured_image} />
									)}
								</div>
								<div>
									{tags[0] && (
										<span class="cat-chip">{tags[0].label}</span>
									)}
									<h3>{post.data.title}</h3>
									<div class="meta">
										{bylines[0]?.byline.displayName}
										{bylines[0] && post.data.publishedAt && " · "}
										{fmtDate(post.data.publishedAt)}
										{readingTime && ` · ${readingTime} min`}
									</div>
								</div>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>
	)}

	{/* ===== PATH CARDS ===== */}
	<section class="paths">
		<div class="container">
			<div class="paths-grid">
				<a class="path-card" href="/guides">
					<div>
						<div class="kicker">Start here</div>
						<h2>I need a bag.</h2>
						<p>
							In-depth buying guides and comparisons. Cut through marketing to the
							gear that actually works.
						</p>
					</div>
					<div class="pathcta">
						Browse Buyer's Guides <span class="arrow">↗</span>
					</div>
				</a>
				<a class="path-card accent" href="/posts">
					<div>
						<div class="kicker">Or just read</div>
						<h2>I'm browsing.</h2>
						<p>
							Reviews, dispatches, and travel notes from the road. Two thousand
							stories and counting.
						</p>
					</div>
					<div class="pathcta">
						Latest Stories <span class="arrow">↗</span>
					</div>
				</a>
			</div>
		</div>
	</section>

	{/* ===== LATEST STORIES ===== */}
	{featureStory && (
		<section class="section">
			<div class="container">
				<div class="section-head">
					<h2>Latest <span class="sub">Stories</span></h2>
					<span class="meta">Updated daily</span>
					<a class="viewall" href="/posts">View all →</a>
				</div>

				<div class="feature-row">
					<a class="story feature-story" href={`/${featureStory.post.id}`}>
						<div class="pic">
							{featureStory.post.data.featured_image && (
								<Image image={featureStory.post.data.featured_image} />
							)}
						</div>
						{featureStory.tags[0] && (
							<span class="cat-chip">{featureStory.tags[0].label}</span>
						)}
						<h3>{featureStory.post.data.title}</h3>
						{featureStory.post.data.excerpt && (
							<p class="excerpt">{featureStory.post.data.excerpt}</p>
						)}
						<div class="meta">
							{featureStory.bylines[0] && (
								<span>
									By <strong>{featureStory.bylines[0].byline.displayName}</strong>
								</span>
							)}
							{featureStory.post.data.publishedAt && (
								<span>{fmtDate(featureStory.post.data.publishedAt)}</span>
							)}
							{featureStory.readingTime && <span>{featureStory.readingTime} min</span>}
						</div>
					</a>

					<div class="more-from-section">
						<h4 class="more-head">More from this week</h4>
						<ul class="more-list">
							{riverPosts.slice(0, 5).map(({ post, bylines, readingTime }) => (
								<li>
									<a class="more-link" href={`/${post.id}`}>
										<h5>{post.data.title}</h5>
										<div class="more-meta">
											{bylines[0]?.byline.displayName}
											{bylines[0] && post.data.publishedAt && " · "}
											{fmtDate(post.data.publishedAt)}
											{readingTime && ` · ${readingTime} min`}
										</div>
									</a>
								</li>
							))}
						</ul>
					</div>
				</div>

				{riverPosts.length > 0 && (
					<div class="river">
						{riverPosts.map(({ post, tags, bylines, readingTime }) => (
							<PostCard
								title={post.data.title ?? "Untitled"}
								excerpt={post.data.excerpt}
								featuredImage={post.data.featured_image}
								href={`/${post.id}`}
								date={post.data.publishedAt ?? undefined}
								readingTime={readingTime}
								tags={tags}
								bylines={bylines}
							/>
						))}
					</div>
				)}
			</div>
		</section>
	)}

	{/* ===== BUYER'S GUIDES STRIP ===== */}
	{guidesWithMeta.length > 0 && (
		<section class="guides-strip">
			<div class="container">
				<div class="section-head">
					<h2>Buyer's <span class="sub">Guides</span></h2>
					<span class="meta">In-depth · Evergreen</span>
					<a class="viewall" href="/guides">All guides →</a>
				</div>
				<div class="guides-grid">
					{guidesWithMeta.map(({ guide, tags, readingTime }) => (
						<a class="guide-card" href={`/guides/${guide.id}`}>
							<div>
								<div class="kicker">
									{tags[0]?.label ?? "Guide"}
									{readingTime ? ` · ${readingTime} min read` : ""}
								</div>
								<h3>{guide.data.title}</h3>
								<div class="meta">
									{guide.data.excerpt && (
										<span class="excerpt">{guide.data.excerpt}</span>
									)}
								</div>
							</div>
							<div class="pic">
								{guide.data.featured_image && (
									<Image image={guide.data.featured_image} />
								)}
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}
</Base>

<style>
	/* ===== HERO ===== */
	.hero {
		padding: 28px 0 36px;
		border-bottom: 1px solid var(--rule);
	}
	.hero-grid {
		display: grid;
		grid-template-columns: 2.1fr 1fr;
		gap: 28px;
	}
	@media (max-width: 900px) {
		.hero-grid { grid-template-columns: 1fr; }
	}

	.hero-lead {
		position: relative;
		overflow: hidden;
		border-radius: var(--radius);
		background: var(--ink);
		aspect-ratio: 16/9;
		display: block;
		color: white;
		cursor: pointer;
	}
	.hero-lead-pic { position: absolute; inset: 0; }
	.hero-lead-pic :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 500ms ease;
	}
	.hero-lead:hover .hero-lead-pic :global(img) { transform: scale(1.03); }

	.hero-lead .overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			180deg,
			rgba(0, 0, 0, 0.05) 0%,
			rgba(0, 0, 0, 0) 40%,
			rgba(0, 0, 0, 0.85) 100%
		);
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 32px 36px;
		color: white;
	}
	.hero-lead .overlay .cat {
		display: inline-flex;
		align-self: flex-start;
		background: var(--accent);
		color: white;
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		padding: 4px 9px;
		margin-bottom: 14px;
	}
	.hero-lead h1 {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: clamp(26px, 3.2vw, 48px);
		line-height: 1.03;
		letter-spacing: -0.028em;
		margin: 0 0 10px;
		color: white;
		max-width: 900px;
	}
	.hero-lead .dek {
		font-size: 16px;
		line-height: 1.45;
		color: rgba(255, 255, 255, 0.85);
		max-width: 680px;
		margin: 0 0 14px;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.hero-lead .meta {
		display: flex;
		gap: 14px;
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(255, 255, 255, 0.7);
		flex-wrap: wrap;
	}
	.hero-lead .meta strong { color: white; font-weight: 600; }

	.hero-stack { display: flex; flex-direction: column; gap: 16px; }
	.hero-stack-item {
		display: grid;
		grid-template-columns: 120px 1fr;
		gap: 14px;
		padding-bottom: 16px;
		border-bottom: 1px solid var(--rule);
		color: inherit;
		cursor: pointer;
	}
	.hero-stack-item:last-child { border-bottom: 0; padding-bottom: 0; }
	.hero-stack-item .pic {
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background: var(--bg-alt);
		border-radius: var(--radius);
	}
	.hero-stack-item .pic :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 400ms ease;
	}
	.hero-stack-item:hover .pic :global(img) { transform: scale(1.04); }
	.hero-stack-item .cat-chip { margin-bottom: 4px; }
	.hero-stack-item h3 {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 15px;
		line-height: 1.25;
		letter-spacing: -0.012em;
		margin: 0 0 4px;
		color: var(--ink);
		transition: color var(--transition-fast);
	}
	.hero-stack-item:hover h3 { color: var(--accent); }
	.hero-stack-item .meta {
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	/* ===== PATHS ===== */
	.paths {
		padding: 40px 0;
		border-bottom: 1px solid var(--rule);
	}
	.paths-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 12px;
	}
	@media (max-width: 700px) {
		.paths-grid { grid-template-columns: 1fr; }
	}

	.path-card {
		position: relative;
		padding: 32px;
		background: var(--surface);
		border: 1px solid var(--rule);
		border-radius: var(--radius-lg);
		cursor: pointer;
		transition: transform 200ms ease, box-shadow 200ms ease,
			border-color 200ms ease;
		min-height: 180px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		color: var(--ink);
	}
	.path-card:hover {
		border-color: var(--ink);
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
	}
	.path-card:hover .arrow {
		transform: translate(4px, -4px);
		color: var(--accent);
	}
	.path-card .kicker {
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		margin-bottom: 10px;
	}
	.path-card h2 {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 28px;
		line-height: 1.1;
		letter-spacing: -0.025em;
		margin: 0 0 8px;
	}
	.path-card p {
		font-size: 14px;
		color: var(--ink-3);
		line-height: 1.5;
		margin: 0 0 20px;
		max-width: 400px;
	}
	.path-card .pathcta {
		display: flex;
		align-items: center;
		gap: 8px;
		font-family: var(--font-mono);
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}
	.path-card .arrow {
		display: inline-block;
		transition: transform 160ms ease;
	}
	.path-card.accent {
		background: var(--accent);
		border-color: var(--accent);
		color: white;
	}
	.path-card.accent .kicker { color: rgba(255, 255, 255, 0.8); }
	.path-card.accent p { color: rgba(255, 255, 255, 0.85); }
	.path-card.accent:hover { border-color: var(--accent-2); background: var(--accent-2); }
	.path-card.accent:hover .arrow { color: white; }

	/* ===== SECTION FRAMING ===== */
	.section {
		padding: 40px 0;
		border-bottom: 1px solid var(--rule);
	}
	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding-bottom: 16px;
		margin-bottom: 20px;
		border-bottom: 2px solid var(--ink);
		gap: 16px;
		flex-wrap: wrap;
	}
	.section-head h2 {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 22px;
		letter-spacing: -0.02em;
		margin: 0;
		color: var(--ink);
	}
	.section-head h2 .sub { color: var(--accent); }
	.section-head .meta {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		flex: 1;
	}
	.section-head a.viewall {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--ink);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 600;
	}
	.section-head a.viewall:hover { color: var(--accent); }

	/* ===== FEATURE ROW ===== */
	.feature-row {
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: 32px;
		margin-bottom: 32px;
	}
	@media (max-width: 800px) {
		.feature-row { grid-template-columns: 1fr; }
	}

	.feature-story {
		color: inherit;
		cursor: pointer;
		display: flex;
		flex-direction: column;
	}
	.feature-story .pic {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--bg-alt);
		border-radius: var(--radius);
		margin-bottom: 14px;
	}
	.feature-story .pic :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 400ms ease;
	}
	.feature-story:hover .pic :global(img) { transform: scale(1.04); }
	.feature-story .cat-chip {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		margin-bottom: 8px;
	}
	.feature-story h3 {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 28px;
		line-height: 1.1;
		letter-spacing: -0.022em;
		margin: 0 0 10px;
		color: var(--ink);
		transition: color var(--transition-fast);
	}
	.feature-story:hover h3 { color: var(--accent); }
	.feature-story .excerpt {
		font-size: 15px;
		color: var(--ink-3);
		line-height: 1.55;
		margin: 0 0 12px;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.feature-story .meta {
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
	}
	.feature-story .meta strong { color: var(--ink-2); font-weight: 600; }

	/* ===== MORE FROM SECTION (alongside feature) ===== */
	.more-from-section { display: flex; flex-direction: column; }
	.more-head {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ink-3);
		margin: 0 0 8px;
		padding-bottom: 10px;
		border-bottom: 1px solid var(--rule);
	}
	.more-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.more-list li { border-bottom: 1px solid var(--rule); }
	.more-list li:last-child { border-bottom: 0; }
	.more-link {
		display: block;
		padding: 14px 0;
		color: inherit;
	}
	.more-link h5 {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 15px;
		line-height: 1.3;
		letter-spacing: -0.01em;
		margin: 0 0 4px;
		color: var(--ink);
		transition: color var(--transition-fast);
	}
	.more-link:hover h5 { color: var(--accent); }
	.more-meta {
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	/* ===== RIVER GRID ===== */
	.river {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px 20px;
	}
	@media (max-width: 1000px) {
		.river { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 600px) {
		.river { grid-template-columns: 1fr; }
	}

	/* ===== GUIDES STRIP (dark) ===== */
	.guides-strip {
		padding: 48px 0;
		background: var(--ink);
		color: var(--bg);
	}
	.guides-strip .section-head { border-bottom-color: var(--bg); }
	.guides-strip .section-head h2 { color: var(--bg); }
	.guides-strip .section-head .meta { color: rgba(255, 255, 255, 0.6); }
	.guides-strip .section-head a.viewall { color: var(--bg); }
	.guides-strip .section-head a.viewall:hover { color: var(--accent); }

	.guides-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
	}
	@media (max-width: 900px) {
		.guides-grid { grid-template-columns: 1fr; }
	}

	.guide-card {
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.1);
		padding: 24px;
		border-radius: var(--radius-lg);
		cursor: pointer;
		transition: background 180ms ease, border-color 180ms ease;
		display: grid;
		grid-template-columns: 1fr 88px;
		gap: 16px;
		align-items: center;
		color: inherit;
	}
	.guide-card:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: var(--accent);
	}
	.guide-card .kicker {
		font-family: var(--font-mono);
		font-size: 10px;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--accent);
		margin-bottom: 8px;
	}
	.guide-card h3 {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 18px;
		line-height: 1.2;
