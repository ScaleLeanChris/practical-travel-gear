---
import { getEmDashCollection, getEntryTerms } from "emdash";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import Sidebar from "../components/Sidebar.astro";
import { getReadingTime } from "../utils/reading-time";

const page = Number(Astro.url.searchParams.get("page") || "1");
const perPage = 10;

const { entries: allPosts, cacheHint } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

const totalPages = Math.ceil(allPosts.length / perPage);
const currentPage = Math.max(1, Math.min(page, totalPages));
const paginatedPosts = allPosts.slice((currentPage - 1) * perPage, currentPage * perPage);

// Fetch tags + bylines for paginated posts
const postsWithMeta = await Promise.all(
	paginatedPosts.map(async (post) => {
		const tags = await getEntryTerms("posts", post.data.id, "tag");
		return {
			post,
			tags: tags.map((t) => ({ slug: t.slug, label: t.label })),
			bylines: post.data.bylines ?? [],
		};
	})
);
---

<Base title="Honest Travel Gear Reviews and Advice" description="Practical Travel Gear provides honest reviews, buying guides, and travel tips.">
	<div class="home-layout">
		<div class="home-main">
			{postsWithMeta.map(({ post, tags, bylines }) => (
				<PostCard
					title={post.data.title ?? "Untitled"}
					excerpt={post.data.excerpt}
					featuredImage={post.data.featured_image}
					href={`/${post.id}`}
					date={post.data.publishedAt ?? undefined}
					readingTime={getReadingTime(post.data.content)}
					tags={tags}
					bylines={bylines}
				/>
			))}

			{/* Pagination */}
			{totalPages > 1 && (
				<div class="pagination">
					<span class="page-info">Page {currentPage} of {totalPages}</span>
					{currentPage < totalPages && (
						<a href={`/?page=${currentPage + 1}`} class="page-link">Next &raquo;</a>
					)}
					{currentPage > 1 && (
						<a href={currentPage === 2 ? "/" : `/?page=${currentPage - 1}`} class="page-link">&laquo; Previous</a>
					)}
				</div>
			)}
		</div>

		<div class="home-sidebar">
			<Sidebar />
		</div>
	</div>
</Base>

<style>
	.home-layout {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-10) var(--spacing-6);
		display: grid;
		grid-template-columns: 1fr var(--sidebar-width);
		gap: var(--spacing-10);
		align-items: start;
	}

	.home-main {
		min-width: 0;
	}

	.home-sidebar {
		position: sticky;
		top: var(--spacing-10);
	}

	/* Pagination */
	.pagination {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: var(--spacing-4);
		padding: var(--spacing-8) 0;
	}

	.page-info {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.page-link {
		display: inline-block;
		padding: var(--spacing-2) var(--spacing-5);
		background: var(--color-nav-bg);
		color: white;
		font-size: var(--font-size-sm);
		font-weight: 600;
		text-decoration: none;
		border-radius: 30px;
		transition: background var(--transition-fast);
	}

	.page-link:hover {
		background: var(--color-accent);
		color: white;
	}

	/* Responsive */
	@media (max-width: 900px) {
		.home-layout {
			grid-template-columns: 1fr;
		}

		.home-sidebar {
			position: static;
		}
	}
</style>
