---
import { getEmDashCollection, getTaxonomyTerms, getMenu } from "emdash";

const [{ entries: recentPosts }, tags, socialMenu] = await Promise.all([
	getEmDashCollection("posts", {
		orderBy: { published_at: "desc" },
		limit: 4,
	}),
	getTaxonomyTerms("tag"),
	getMenu("social"),
]);

const socialIcons: Record<string, string> = {
	facebook: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>',
	instagram: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>',
	rss: '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.742-7.099-15.783-15.839-15.82zm0-8.18v4.819c12.951.115 23.409 10.627 23.523 23.564h4.477c-.115-15.764-12.843-28.512-28-28.383z"/></svg>',
};
const socialColors: Record<string, string> = {
	facebook: '#3b5998',
	instagram: '#e1306c',
	rss: '#ff6600',
};
const socialSubtitles: Record<string, string> = {
	facebook: 'Follow me!',
	instagram: 'Our photos!',
	rss: 'Get our latest news!',
};
---

<aside class="sidebar">
	<!-- Recent Posts -->
	<div class="sidebar-widget">
		<h3 class="sidebar-heading">Recent posts</h3>
		<div class="recent-posts">
			{recentPosts.map((post) => (
				<a href={`/${post.id}`} class="recent-post">
					{post.data.featured_image && (
						<div class="recent-post-image">
							<img
								src={typeof post.data.featured_image === 'object' && post.data.featured_image.src
									? post.data.featured_image.src
									: `/_emdash/api/media/file/${(post.data.featured_image as any)?.meta?.storageKey || (post.data.featured_image as any)?.id || ''}`}
								alt={post.data.title ?? ''}
								loading="lazy"
							/>
						</div>
					)}
					<div class="recent-post-info">
						<h4>{post.data.title}</h4>
						{post.data.publishedAt && (
							<time>{post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
						)}
					</div>
				</a>
			))}
		</div>
	</div>

	<!-- Tag Cloud -->
	<div class="sidebar-widget">
		<h3 class="sidebar-heading">Tag Cloud</h3>
		<div class="tag-cloud">
			{tags.slice(0, 10).map((tag) => (
				<a href={`/tag/${tag.slug}`} class="tag-pill">#{tag.label}</a>
			))}
		</div>
	</div>

	<!-- Social -->
	<div class="sidebar-widget">
		<h3 class="sidebar-heading">Social</h3>
		<div class="social-links">
			{socialMenu?.items.map((item) => {
				const key = item.label.toLowerCase();
				return (
					<a href={item.url} target={item.target} rel={item.target === '_blank' ? 'noopener noreferrer' : undefined} class="social-card-link">
						<span class="social-icon-box" style={`background: ${socialColors[key] || '#666'}`}>
							<Fragment set:html={socialIcons[key] || socialIcons.rss} />
						</span>
						<span class="social-card-text"><strong>{item.label}</strong><br/><small>{socialSubtitles[key] || 'Follow us!'}</small></span>
					</a>
				);
			})}
		</div>
	</div>
</aside>

<style>
	.sidebar {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-10);
	}

	.sidebar-heading {
		font-size: var(--font-size-2xl);
		font-weight: 600;
		color: var(--color-text);
		margin-bottom: var(--spacing-6);
		padding-bottom: var(--spacing-3);
		border-bottom: 2px solid var(--color-accent);
		display: inline-block;
	}

	/* Recent posts */
	.recent-posts {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-4);
	}

	.recent-post {
		display: flex;
		gap: var(--spacing-3);
		text-decoration: none;
		color: inherit;
	}

	.recent-post:hover h4 {
		color: var(--color-accent);
	}

	.recent-post-image {
		flex-shrink: 0;
		width: 80px;
		height: 60px;
		border-radius: var(--radius);
		overflow: hidden;
	}

	.recent-post-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.recent-post-info h4 {
		font-size: var(--font-size-sm);
		font-weight: 600;
		line-height: var(--leading-snug);
		color: var(--color-text);
		margin-bottom: var(--spacing-1);
		transition: color var(--transition-fast);
	}

	.recent-post-info time {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
	}

	/* Tag cloud */
	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
	}

	.tag-pill {
		display: inline-block;
		padding: var(--spacing-1) var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--color-tag);
		background: var(--color-bg);
		border-radius: var(--radius);
		text-decoration: none;
		border: 1px solid var(--color-border);
		transition: all var(--transition-fast);
	}

	.tag-pill:hover {
		background: var(--color-accent);
		color: white;
		border-color: var(--color-accent);
	}

	/* Social */
	.social-links {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
	}

	.social-card-link {
		display: flex;
		align-items: center;
		gap: var(--spacing-3);
		padding: var(--spacing-3) var(--spacing-4);
		background: var(--color-bg);
		border-radius: var(--radius-lg);
		text-decoration: none;
		color: var(--color-text);
		border: 1px solid var(--color-border-subtle);
		transition: background var(--transition-fast);
	}

	.social-card-link:hover {
		background: var(--color-border-subtle);
		color: var(--color-text);
	}

	.social-card-text small {
		color: var(--color-muted);
	}

	.social-icon-box {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: var(--radius);
		color: white;
		flex-shrink: 0;
	}

	/* icon box colors set via inline style from socialColors map */
</style>
