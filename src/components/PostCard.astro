---
import type { MediaValue, ContentBylineCredit } from "emdash";
import { Image } from "emdash/ui";

interface Props {
	title: string;
	excerpt?: string;
	featuredImage?: MediaValue | string;
	href: string;
	date?: Date;
	readingTime?: number;
	tags?: Array<{ slug: string; label: string }>;
	bylines?: ContentBylineCredit[];
	/** Shown as the orange category chip above the title */
	kicker?: string;
	/** Optional badge rendered on the image (top-left) */
	badge?: string;
	/** 'default' full card, 'compact' = smaller for grid cells, 'feature' = larger headline */
	variant?: "default" | "compact" | "feature";
}

const {
	title,
	excerpt,
	featuredImage,
	href,
	date,
	readingTime,
	tags,
	bylines,
	kicker,
	badge,
	variant = "default",
} = Astro.props;

const formattedDate = date
	? date.toLocaleDateString("en-US", {
			month: "short",
			day: "numeric",
			year: "numeric",
		})
	: null;

const authorName =
	bylines && bylines.length > 0 ? bylines[0].byline.displayName : null;

const chip = kicker ?? (tags && tags.length > 0 ? tags[0].label : null);
---

<article class={`story story--${variant}`}>
	<a href={href} class="story-inner">
		{featuredImage && (
			<div class="pic">
				<Image image={featuredImage} />
				{badge && <span class="badge accent">{badge}</span>}
			</div>
		)}
		<div class="body">
			{chip && <span class="cat-chip">{chip}</span>}
			<h3 class="title">{title}</h3>
			{excerpt && <p class="excerpt">{excerpt}</p>}
			<div class="meta">
				{authorName && <span><strong>{authorName}</strong></span>}
				{formattedDate && <span>{formattedDate}</span>}
				{readingTime && <span>{readingTime} min</span>}
			</div>
		</div>
	</a>
</article>

<style>
	.story { cursor: pointer; }
	.story-inner {
		display: flex;
		flex-direction: column;
		color: inherit;
		text-decoration: none;
	}

	.pic {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--bg-alt);
		border-radius: var(--radius);
		margin-bottom: 12px;
		position: relative;
	}
	.pic :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 400ms ease;
	}
	.story:hover .pic :global(img) { transform: scale(1.04); }

	.badge {
		position: absolute;
		top: 10px;
		left: 10px;
		padding: 4px 8px;
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		border-radius: 2px;
		background: var(--bg);
		color: var(--ink);
	}
	.badge.accent { background: var(--accent); color: white; }

	.body { display: flex; flex-direction: column; }

	.cat-chip {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--accent);
		margin-bottom: 6px;
	}

	.title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 17px;
		line-height: 1.25;
		letter-spacing: -0.015em;
		margin: 0 0 8px;
		color: var(--ink);
		transition: color var(--transition-fast);
	}
	.story:hover .title { color: var(--accent); }

	.excerpt {
		font-size: 14px;
		color: var(--ink-3);
		line-height: 1.5;
		margin: 0 0 10px;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.meta {
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--ink-3);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
	}
	.meta strong {
		color: var(--ink-2);
		font-weight: 600;
	}

	/* Feature variant: bigger headline, bigger excerpt, feels like lead story */
	.story--feature .title {
		font-size: 28px;
		letter-spacing: -0.022em;
		line-height: 1.1;
	}
	.story--feature .excerpt {
		font-size: 15px;
		-webkit-line-clamp: 3;
	}

	/* Compact variant: smaller everything, for dense grids */
	.story--compact .title { font-size: 15px; }
	.story--compact .excerpt { -webkit-line-clamp: 2; }
</style>
