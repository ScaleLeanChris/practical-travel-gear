---
import type { MediaValue, ContentBylineCredit } from "emdash";
import { Image } from "emdash/ui";

interface Props {
	title: string;
	excerpt?: string;
	featuredImage?: MediaValue | string;
	href: string;
	date?: Date;
	readingTime?: number;
	tags?: Array<{ slug: string; label: string }>;
	bylines?: ContentBylineCredit[];
}

const {
	title,
	excerpt,
	featuredImage,
	href,
	date,
	readingTime,
	tags,
	bylines,
} = Astro.props;

const formattedDate = date
	? date.toLocaleDateString("en-US", {
			year: "numeric",
			month: "long",
			day: "numeric",
		})
	: null;

const authorName = bylines && bylines.length > 0 ? bylines[0].byline.displayName : null;
---

<article class="post-card">
	<div class="card-inner">
		{featuredImage && (
			<a href={href} class="card-image-link">
				<div class="card-image">
					<Image image={featuredImage} />
				</div>
				<div class="card-image-overlay">
					<span class="card-overlay-title">{title}</span>
				</div>
			</a>
		)}
		<div class="card-content">
			<div class="card-header">
				<h2 class="card-title">
					<a href={href}>{title}</a>
				</h2>
				<div class="card-meta">
					{formattedDate && <time>{formattedDate}</time>}
					{formattedDate && <span class="meta-sep">&mdash;</span>}
					{readingTime && <span>{readingTime} Min Read</span>}
				</div>
			</div>

			{excerpt && <p class="card-excerpt">{excerpt}</p>}

			<div class="card-footer">
				<div class="card-tags">
					{tags && tags.map((tag) => (
						<a href={`/tag/${tag.slug}`} class="card-tag">#{tag.label}</a>
					))}
				</div>
				{authorName && <span class="card-author">{authorName}</span>}
			</div>

			<a href={href} class="continue-reading">Continue Reading</a>
		</div>
	</div>
</article>

<style>
	.post-card {
		background: var(--color-surface);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-card);
		overflow: hidden;
		margin-bottom: var(--spacing-8);
	}

	.card-inner {
		display: grid;
		grid-template-columns: 200px 1fr;
		min-height: 0;
	}

	.card-image-link {
		position: relative;
		display: block;
		overflow: hidden;
	}

	.card-image {
		width: 100%;
		height: 100%;
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.card-image-link:hover .card-image img {
		transform: scale(1.05);
	}

	.card-image-overlay {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		background: linear-gradient(transparent, rgba(0,0,0,0.7));
		padding: var(--spacing-4) var(--spacing-3);
	}

	.card-overlay-title {
		color: white;
		font-size: var(--font-size-sm);
		font-weight: 600;
		line-height: var(--leading-snug);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-content {
		padding: var(--spacing-6);
		display: flex;
		flex-direction: column;
	}

	.card-title {
		font-size: var(--font-size-xl);
		font-weight: 600;
		line-height: var(--leading-snug);
		margin-bottom: var(--spacing-2);
	}

	.card-title a {
		color: var(--color-text);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.card-title a:hover {
		color: var(--color-accent);
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-2);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
	}

	.meta-sep {
		color: var(--color-accent);
	}

	.card-excerpt {
		font-size: var(--font-size-base);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-4);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
	}

	.card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: var(--spacing-4);
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
	}

	.card-tag {
		font-size: var(--font-size-sm);
		color: var(--color-tag);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.card-tag:hover {
		color: var(--color-accent);
	}

	.card-author {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		font-style: italic;
	}

	.continue-reading {
		display: inline-block;
		align-self: flex-start;
		padding: 8px 25px;
		background: var(--color-nav-bg);
		color: white;
		font-size: var(--font-size-sm);
		font-weight: 600;
		text-decoration: none;
		border-radius: 30px;
		transition: background var(--transition-fast);
	}

	.continue-reading:hover {
		background: var(--color-accent);
		color: white;
	}

	/* Responsive */
	@media (max-width: 640px) {
		.card-inner {
			grid-template-columns: 1fr;
		}

		.card-image-link {
			height: 200px;
		}
	}
</style>
